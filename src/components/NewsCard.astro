---
interface Props {
  headline: string;
  summary: string;
  category: string;
  source: string;
  sourceUrl?: string;
  date: string;
  relevanceScore: number;
  variant?: 'default' | 'featured' | 'compact';
}

const { headline, summary, category, source, sourceUrl, date, relevanceScore, variant = 'default' } = Astro.props;

const categoryConfig: Record<string, { label: string; bg: string; color: string; border: string }> = {
  research: {
    label: 'Research',
    bg: 'rgba(91, 58, 163, 0.1)',
    color: '#5b3aa3',
    border: 'rgba(91, 58, 163, 0.25)',
  },
  industrie: {
    label: 'Industrie',
    bg: 'rgba(26, 24, 20, 0.06)',
    color: '#1a1814',
    border: 'rgba(26, 24, 20, 0.15)',
  },
  open_source: {
    label: 'Open Source',
    bg: 'rgba(45, 90, 63, 0.1)',
    color: '#2d5a3f',
    border: 'rgba(45, 90, 63, 0.25)',
  },
  politik: {
    label: 'Politik',
    bg: 'rgba(184, 114, 28, 0.1)',
    color: '#b8721c',
    border: 'rgba(184, 114, 28, 0.25)',
  },
  produkt: {
    label: 'Produkt',
    bg: 'rgba(139, 44, 77, 0.1)',
    color: '#8b2c4d',
    border: 'rgba(139, 44, 77, 0.25)',
  },
};

const cat = categoryConfig[category] || categoryConfig['research'];

const formattedDate = new Date(date).toLocaleDateString('de-DE', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});

// Wenn sourceUrl vorhanden: die ganze Card ist klickbar.
const Tag = sourceUrl ? 'a' : 'article';
const linkAttrs = sourceUrl
  ? { href: sourceUrl, target: '_blank', rel: 'noopener noreferrer' }
  : {};

// Host-Display: zeigt Domain aus URL (z.B. "anthropic.com")
const hostFromUrl = sourceUrl
  ? (() => {
      try {
        return new URL(sourceUrl).hostname.replace(/^www\./, '');
      } catch {
        return null;
      }
    })()
  : null;
---

<Tag
  {...linkAttrs}
  class={`news-card group relative rounded-2xl paper-elevated overflow-hidden hover:bg-bg-card-hover transition-all duration-500 hover:-translate-y-1 flex flex-col w-full h-full ${variant === 'featured' ? 'p-8 md:p-10' : 'p-6'}`}
  data-category={category}
  data-relevance={relevanceScore}
>
  <!-- Top row -->
  <div class="flex items-start justify-between gap-3 mb-5">
    <span
      class="inline-flex items-center px-3 py-1 rounded-full text-[11px] font-mono uppercase tracking-[0.08em] font-medium border"
      style={`background: ${cat.bg}; color: ${cat.color}; border-color: ${cat.border};`}
    >
      {cat.label}
    </span>
    <!-- Relevance dots -->
    <div class="flex items-center gap-0.5" title={`Relevanz: ${relevanceScore}/10`}>
      {Array.from({ length: 10 }, (_, i) => (
        <div class={`w-0.5 h-3 rounded-full transition-colors ${i < relevanceScore ? 'bg-accent-deep' : 'bg-border-strong'}`}></div>
      ))}
    </div>
  </div>

  <!-- Headline -->
  <h3 class={`font-display font-normal text-text-primary mb-3 leading-tight group-hover:text-accent-deep transition-colors duration-300 ${variant === 'featured' ? 'text-2xl md:text-4xl' : 'text-xl md:text-2xl'}`}>
    {headline}
  </h3>

  <!-- Summary -->
  <p class="text-text-secondary text-sm leading-relaxed mb-5 font-light flex-1">
    {summary}
  </p>

  <!-- Footer -->
  <div class="flex items-center justify-between gap-3 text-xs mt-auto">
    <div class="flex items-center gap-2 font-mono text-text-muted min-w-0">
      <span class="truncate">{source}</span>
      <span class="shrink-0">·</span>
      <time class="shrink-0" datetime={date}>{formattedDate}</time>
    </div>
    {sourceUrl ? (
      <span class="inline-flex items-center gap-1 font-mono text-[11px] text-text-muted group-hover:text-accent-deep shrink-0 transition-colors">
        <span class="hidden sm:inline">Quelle lesen</span>
        <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </span>
    ) : (
      <svg class="w-4 h-4 text-text-muted shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
    )}
  </div>
</Tag>

<style>
  /* news-card als <a>: Reset von Link-Defaults */
  a.news-card {
    text-decoration: none;
    color: inherit;
  }
  a.news-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }
</style>
