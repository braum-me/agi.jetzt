---
import landscapeData from '../data/landscape.json';
import newsData from '../data/news.json';
import BrandLogo from './BrandLogo.astro';

const categories = [
  {
    key: 'frontier_lab',
    label: 'Frontier Labs',
    description: 'Die führenden KI-Forschungslabore der Welt',
    color: '#5b3aa3',
  },
  {
    key: 'open_source',
    label: 'Open Source',
    description: 'Offene Modelle und Communities',
    color: '#2d5a3f',
  },
  {
    key: 'hardware',
    label: 'Hardware',
    description: 'Die Chips hinter der KI-Revolution',
    color: '#b8721c',
  },
  {
    key: 'application',
    label: 'Anwendungen',
    description: 'KI-Produkte für Endnutzer',
    color: '#8b2c4d',
  },
];

const brandMap: Record<string, string> = {
  openai: 'openai',
  anthropic: 'anthropic',
  deepmind: 'deepmind',
  'meta-ai': 'meta',
  mistral: 'mistral',
  xai: 'xai',
  huggingface: 'huggingface',
  deepseek: 'deepseek',
  zhipu: 'zhipu',
  gemma: 'gemma',
  'stability-ai': 'stability',
  nvidia: 'nvidia',
  amd: 'amd',
  cerebras: 'cerebras',
  groq: 'groq',
  'chatgpt-app': 'chatgpt',
  'claude-app': 'claude',
  perplexity: 'perplexity',
};

// Build news lookup by id
const newsById = Object.fromEntries(newsData.map((n: any) => [n.id, n]));
---

<section id="landscape" class="relative py-20 md:py-28 overflow-hidden">
  <div class="section-container relative">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="badge mb-6 mx-auto">
        <span class="w-1 h-1 rounded-full bg-accent"></span>
        Das Ökosystem
      </div>
      <h2 class="font-display font-normal text-balance leading-[1.05] text-[clamp(1.875rem,6vw,5rem)] mb-6">
        Wer baut<br/>
        <em class="italic gradient-text">die Zukunft</em>?
      </h2>
      <p class="text-text-secondary text-lg md:text-xl leading-relaxed font-light">
        Vier Welten, ein Ziel. Jeder Akteur bewertet nach AGI-Relevanz (0–10),
        mit Live-News-Verbindung wo möglich.
      </p>
    </div>

    <!-- Categories -->
    <div class="space-y-20 md:space-y-28">
      {categories.map((cat) => {
        const items = landscapeData.filter((item: any) => item.category === cat.key);
        return (
          <div class="landscape-category">
            <!-- Category header -->
            <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10 pb-5 border-b border-border">
              <div class="flex items-center gap-4">
                <div class="w-1 h-12 rounded-full" style={`background: ${cat.color};`}></div>
                <div>
                  <div class="text-[10px] font-mono uppercase tracking-[0.25em] mb-2" style={`color: ${cat.color};`}>
                    {String(items.length).padStart(2, '0')} Akteure
                  </div>
                  <h3 class="font-display font-normal text-3xl md:text-4xl text-text-primary">
                    {cat.label}
                  </h3>
                </div>
              </div>
              <p class="md:max-w-xs text-text-secondary text-sm leading-relaxed">
                {cat.description}
              </p>
            </div>

            <!-- Brand Cards — Grid 2 cols on desktop, larger cards with info -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              {items.map((item: any) => {
                const brand = brandMap[item.id] || 'default';
                const linkedNews = item.news_id ? newsById[item.news_id] : null;
                const score = item.agi_relevance || 0;
                return (
                  <article
                    class="landscape-card group relative paper-elevated rounded-2xl overflow-hidden transition-all duration-500 hover:-translate-y-1 hover:bg-bg-card-hover"
                    style={`padding: 1.75rem; --brand-color: ${cat.color};`}
                  >
                    <div class="flex flex-col h-full">
                      <!-- Top: Logo + Score -->
                      <div class="flex items-start justify-between gap-5 mb-5">
                        <!-- Logo (monochrome → color on hover) -->
                        <div class="shrink-0 brand-logo text-text-muted group-hover:text-[var(--brand-color)] transition-colors duration-500">
                          <BrandLogo brand={brand} />
                        </div>

                        <!-- AGI Relevance Score -->
                        <div class="shrink-0 flex flex-col items-end">
                          <div class="text-[9px] font-mono uppercase tracking-[0.2em] text-text-muted mb-1">
                            AGI-Relevanz
                          </div>
                          <div class="flex items-baseline gap-1">
                            <span
                              class="font-display tabular-nums leading-none"
                              style={`font-size: 2rem; color: ${score >= 9 ? 'var(--color-burgundy)' : score >= 7 ? 'var(--color-accent-deep)' : 'var(--color-text-secondary)'};`}
                            >
                              {score}
                            </span>
                            <span class="text-xs font-mono text-text-muted">/10</span>
                          </div>
                          <!-- Score bar -->
                          <div class="mt-1.5 flex gap-0.5">
                            {Array.from({ length: 10 }, (_, i) => (
                              <div
                                class="h-1 w-1.5 rounded-full"
                                style={`background: ${i < score ? cat.color : 'var(--color-border)'};`}
                              ></div>
                            ))}
                          </div>
                        </div>
                      </div>

                      <!-- Name + Location -->
                      <div class="mb-4">
                        <h4 class="font-display font-normal text-text-primary text-2xl leading-tight mb-1">
                          {item.name}
                        </h4>
                        <div class="flex items-center gap-2 text-[11px] font-mono uppercase tracking-wider text-text-muted">
                          <span>{item.headquarters?.split(',')[0] || '—'}</span>
                          <span>·</span>
                          <span>seit {item.founded}</span>
                        </div>
                      </div>

                      <!-- Description -->
                      <p class="text-text-secondary text-sm leading-relaxed mb-4 flex-1">
                        {item.description}
                      </p>

                      <!-- Why it matters -->
                      <div class="mb-4 pl-3 border-l-2" style={`border-color: ${cat.color};`}>
                        <div class="text-[10px] font-mono uppercase tracking-[0.2em] text-text-muted mb-1.5">
                          Warum relevant
                        </div>
                        <p class="text-sm text-text-primary leading-relaxed">
                          {item.why_matters}
                        </p>
                      </div>

                      <!-- Key Products -->
                      <div class="flex flex-wrap gap-1.5 mb-4">
                        {item.key_products?.map((p: string) => (
                          <span class="text-[11px] font-mono px-2 py-0.5 rounded-md bg-bg-secondary text-text-secondary">
                            {p}
                          </span>
                        ))}
                      </div>

                      <!-- Linked News (if available) -->
                      {linkedNews && (
                        <a
                          href="#news"
                          class="group/news flex items-center gap-3 pt-3 border-t border-border text-xs hover:bg-bg-card-hover rounded-lg -mx-2 px-2 -mb-1 pb-3 transition-colors"
                        >
                          <span class="text-[10px] font-mono uppercase tracking-[0.2em]" style={`color: ${cat.color};`}>
                            ● Live
                          </span>
                          <span class="text-text-secondary group-hover/news:text-text-primary transition-colors line-clamp-1 flex-1">
                            {linkedNews.headline}
                          </span>
                          <svg class="w-3 h-3 text-text-muted group-hover/news:translate-x-0.5 transition-transform shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                          </svg>
                        </a>
                      )}

                      {!linkedNews && (
                        <a
                          href={item.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="flex items-center justify-between pt-3 border-t border-border text-xs text-text-muted hover:text-text-primary transition-colors -mx-2 px-2 -mb-1 pb-3 hover:bg-bg-card-hover rounded-lg"
                        >
                          <span class="font-mono">{item.url.replace(/^https?:\/\//, '')}</span>
                          <svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                          </svg>
                        </a>
                      )}
                    </div>
                  </article>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Scoring Methodology Note -->
    <div class="mt-16 max-w-3xl mx-auto paper rounded-2xl p-6 md:p-8">
      <div class="flex items-start gap-4">
        <div class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center bg-accent-soft text-accent-deep">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <h4 class="font-display text-lg text-text-primary mb-2">
            Zur Bewertungslogik
          </h4>
          <p class="text-text-secondary text-sm leading-relaxed mb-2">
            <strong class="text-text-primary">AGI-Relevanz 0–10</strong> gewichtet Fortschritt auf Reasoning-Benchmarks,
            Compute-Zugriff, Open-Source-Impact und Marktmacht.
          </p>
          <p class="text-text-muted text-xs leading-relaxed">
            <span class="font-mono">9–10</span> = strukturell unverzichtbar ·
            <span class="font-mono">7–8</span> = stark wegweisend ·
            <span class="font-mono">5–6</span> = relevanter Mitspieler ·
            <span class="font-mono">&lt;5</span> = spezialisiert
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
