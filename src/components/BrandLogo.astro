---
/**
 * Brand-Logo mit File-First-Strategie:
 *   1. Falls /public/logos/{brand}.svg existiert → <img> laden
 *   2. Sonst → Inline-SVG-Fallback (monochrom, currentColor)
 *
 * Das Vite-import.meta.glob-Lookup erkennt zur Build-Zeit,
 * welche Logo-Dateien vorhanden sind.
 */

interface Props {
  brand: string;
  class?: string;
}

const { brand, class: className = '' } = Astro.props;
const cx = `${className}`;

// Build-time lookup of all logo files in /public/logos/
const logoModules = import.meta.glob('/public/logos/*.svg', { eager: true, query: '?url', import: 'default' });
const availableLogos = new Set(
  Object.keys(logoModules).map((p) => {
    const m = p.match(/\/public\/logos\/([^/]+)\.svg$/);
    return m ? m[1] : '';
  }).filter(Boolean)
);

const hasLogoFile = availableLogos.has(brand);
const logoUrl = hasLogoFile ? `/logos/${brand}.svg` : null;
---

<div class={`brand-logo-wrap ${cx}`}>
{logoUrl && (
  <img src={logoUrl} alt={`${brand} Logo`} loading="lazy" width="56" height="56" />
)}

