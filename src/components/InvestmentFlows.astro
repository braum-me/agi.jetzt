---
/**
 * AI Investment Flows — jährliche Investitionsvolumen
 * Quelle: Stanford AI Index, Dealroom, Crunchbase (approximiert)
 */

interface YearData {
  year: number;
  total: number; // in $B
  private: number;
  highlights: string[];
}

const data: YearData[] = [
  { year: 2018, total: 46, private: 38, highlights: ['Mobileye'] },
  { year: 2019, total: 51, private: 43, highlights: ['Argo AI'] },
  { year: 2020, total: 68, private: 55, highlights: ['Waymo'] },
  { year: 2021, total: 176, private: 144, highlights: ['OpenAI Series B'] },
  { year: 2022, total: 92, private: 75, highlights: ['Anthropic Seed'] },
  { year: 2023, total: 140, private: 110, highlights: ['OpenAI $10B (MSFT)'] },
  { year: 2024, total: 258, private: 189, highlights: ['OpenAI $6.6B (Okt)', 'Anthropic $4B (AMZN)'] },
  { year: 2025, total: 412, private: 298, highlights: ['xAI $20B (Series E)', 'Perplexity $3B', 'Mistral $2B'] },
  { year: 2026, total: 535, private: 395, highlights: ['Anthropic $30B (GIC/Coatue)', 'OpenAI $122B Runde'] },
];

const maxTotal = Math.max(...data.map((d) => d.total));

// Mega-Deals (> $3B)
const megaDeals = [
  { year: 2023, company: 'OpenAI',    amount: 10,   lead: 'Microsoft',     stage: 'Strategic' },
  { year: 2024, company: 'OpenAI',    amount: 6.6,  lead: 'Thrive Capital', stage: 'Series' },
  { year: 2024, company: 'Anthropic', amount: 4,    lead: 'Amazon',        stage: 'Strategic' },
  { year: 2024, company: 'xAI',       amount: 6,    lead: 'Valor Equity',  stage: 'Series B' },
  { year: 2025, company: 'xAI',       amount: 20,   lead: 'Valor + Sequoia', stage: 'Series E (upsized)' },
  { year: 2026, company: 'Anthropic', amount: 30,   lead: 'GIC + Coatue',  stage: 'Series G' },
  { year: 2026, company: 'OpenAI',    amount: 122,  lead: 'SoftBank-Konsortium', stage: 'Strategic' },
];
---

<section id="investments" class="relative py-20 md:py-28">
  <div class="section-container">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="badge mx-auto mb-6">
        <span class="w-1 h-1 rounded-full bg-accent"></span>
        Investment Flows
      </div>
      <h2 class="font-display font-normal text-balance leading-[1.05] text-[clamp(1.875rem,6vw,5rem)] mb-6">
        Wo das <em class="italic gradient-text">Geld</em> hingeht
      </h2>
      <p class="text-text-primary text-lg md:text-xl leading-relaxed font-medium">
        In fünf Jahren von 46 auf 535 Milliarden Dollar. KI ist die größte Kapitalbewegung der Dekade.
      </p>
    </div>

    <!-- Annual bar chart -->
    <div class="paper-elevated rounded-3xl p-6 md:p-10 mb-10">
      <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-6">
        Jährliche KI-Investitionen · $ Mrd · Privat + Öffentlich
      </div>

      <div class="space-y-3">
        {data.map((d) => {
          const width = (d.total / maxTotal) * 100;
          const privateWidth = (d.private / maxTotal) * 100;
          return (
            <div class="investment-row grid grid-cols-[60px_1fr_100px] items-center gap-4">
              <span class="font-display text-lg text-text-primary tabular-nums">{d.year}</span>
              <div class="relative h-8 bg-bg-tertiary rounded-lg overflow-hidden">
                <div
                  class="absolute inset-y-0 left-0 rounded-lg investment-bar-total"
                  style={`width: ${width}%; background: linear-gradient(90deg, #5b3aa3, #8b2c4d); transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1);`}
                  data-bar-width={width}
                ></div>
                <div
                  class="absolute inset-y-0 left-0 rounded-lg investment-bar-private"
                  style={`width: ${privateWidth}%; background: #3d2670; transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1);`}
                  data-bar-width={privateWidth}
                ></div>
              </div>
              <div class="text-right">
                <span class="font-display text-lg text-text-primary tabular-nums">${d.total}</span>
                <span class="text-[10px] font-mono text-text-muted ml-1">Mrd</span>
              </div>
            </div>
          );
        })}
      </div>

      <div class="flex items-center gap-6 mt-6 pt-6 border-t border-border text-xs text-text-muted">
        <div class="flex items-center gap-2">
          <div class="w-3 h-3 rounded-sm" style="background: #3d2670;"></div>
          <span>Private VC + Corp</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-3 h-3 rounded-sm" style="background: linear-gradient(90deg, #5b3aa3, #8b2c4d);"></div>
          <span>Inkl. Public + Partnerschaften</span>
        </div>
      </div>
    </div>

    <!-- Mega Deals -->
    <div class="mb-8">
      <div class="flex items-center gap-4 mb-8">
        <div class="w-1 h-8 rounded-full bg-burgundy"></div>
        <h3 class="font-display text-2xl md:text-3xl text-text-primary">Mega-Deals</h3>
        <div class="flex-1 h-px bg-border"></div>
        <span class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted">
          &gt; $3 Mrd pro Runde
        </span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {megaDeals.map((deal) => (
          <article class="paper-elevated rounded-2xl p-6 hover:bg-bg-card-hover transition-all">
            <div class="flex items-start justify-between gap-3 mb-3">
              <div>
                <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-1">
                  {deal.year} · {deal.stage}
                </div>
                <h4 class="font-display text-2xl text-text-primary">{deal.company}</h4>
              </div>
              <div class="text-right">
                <div class="font-display text-3xl tabular-nums" style="color: var(--color-burgundy);">
                  ${deal.amount}<span class="text-sm opacity-50">B</span>
                </div>
              </div>
            </div>
            <div class="text-xs text-text-secondary pt-3 border-t border-border">
              Lead: <span class="text-text-primary font-medium">{deal.lead}</span>
            </div>
          </article>
        ))}
      </div>
    </div>

    <p class="text-center text-xs font-mono text-text-muted max-w-2xl mx-auto leading-relaxed">
      Quelle: Stanford AI Index 2026 Report, Dealroom, öffentliche SEC-Filings. 2026-Zahlen annualisiert.
    </p>
  </div>
</section>
