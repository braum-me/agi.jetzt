---
import { getCollection } from 'astro:content';

const now = new Date();
const briefings = (await getCollection('briefing', ({ data }) => !data.draft && data.date.valueOf() <= now.valueOf()))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latest = briefings[0];
const previous = briefings[1];

if (!latest) return null;

const fmt = (d: Date) => d.toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' });
const formattedDate = fmt(latest.data.date);
const previousDate = previous ? fmt(previous.data.date) : '';
---

<section id="briefing-teaser" class="relative py-16 md:py-24">
  <div class="section-container">
    <div class="max-w-5xl mx-auto">
      <!-- Header-Zeile mit Label + Link zu allen -->
      <div class="flex items-end justify-between gap-4 mb-8 flex-wrap">
        <div>
          <div class="badge mb-3" style="background: rgba(139, 44, 77, 0.1); border-color: rgba(139, 44, 77, 0.3); color: #8b2c4d;">
            <span class="relative flex h-1.5 w-1.5">
              <span class="absolute inline-flex h-full w-full rounded-full bg-burgundy opacity-75 animate-pulse"></span>
              <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-burgundy"></span>
            </span>
            Aktuelles Briefing · KW {String(latest.data.kw).padStart(2, '0')}
          </div>
          <h2 class="font-display font-normal text-balance leading-[1.05] text-[clamp(1.75rem,4.5vw,3.5rem)]">
            Wöchentliches <em class="italic gradient-text">KI-Briefing</em>
          </h2>
        </div>
        <a
          href="/briefing"
          class="text-sm font-mono text-text-muted hover:text-text-primary transition-colors inline-flex items-center gap-1.5"
        >
          Alle Ausgaben
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <!-- Briefing-Card -->
      <a
        href={`/briefing/${latest.slug}/`}
        class="group block paper-elevated rounded-3xl overflow-hidden no-underline hover:-translate-y-1 hover:bg-bg-card-hover transition-all"
        style="padding: 2.25rem 2.5rem;"
      >
        <div class="flex flex-col md:flex-row md:items-start gap-6 md:gap-10">
          <!-- Linke Spalte: Headline + Stats -->
          <div class="flex-1 min-w-0">
            <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-3">
              Story der Woche · {formattedDate}
            </div>
            <h3 class="font-display font-normal text-2xl md:text-4xl text-text-primary leading-tight mb-4 group-hover:text-accent-deep transition-colors">
              {latest.data.subtitle}
            </h3>
            <p class="text-text-secondary leading-relaxed mb-5 max-w-2xl">
              {latest.data.summary}
            </p>
            <div class="flex items-center gap-2 text-sm font-mono text-text-muted group-hover:text-accent-deep transition-colors">
              <span>Briefing lesen</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </div>

          <!-- Rechte Spalte: Zahl der Woche -->
          <div class="md:w-56 shrink-0 md:border-l md:border-border md:pl-8">
            <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-2">
              Zahl der Woche
            </div>
            <div class="font-display text-4xl md:text-5xl tabular-nums leading-none mb-2" style="color: var(--color-accent-deep);">
              {latest.data.statsHighlight.value}
            </div>
            <div class="text-xs text-text-primary font-medium leading-snug mb-2">
              {latest.data.statsHighlight.label}
            </div>
            <p class="text-[11px] text-text-muted leading-relaxed">
              {latest.data.statsHighlight.context}
            </p>
          </div>
        </div>
      </a>

      {previous && (
        <a
          href={`/briefing/${previous.slug}/`}
          class="prev-briefing group mt-4 flex items-baseline gap-4 md:gap-6 px-6 md:px-8 py-5 rounded-2xl border border-border hover:border-burgundy/40 hover:bg-bg-card-hover transition-all"
        >
          <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted shrink-0 whitespace-nowrap pt-0.5">
            KW {String(previous.data.kw).padStart(2, '0')} · Vorwoche
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-text-primary text-base md:text-lg leading-snug font-medium group-hover:text-accent-deep transition-colors line-clamp-2">
              {previous.data.subtitle}
            </div>
            <div class="text-[11px] font-mono text-text-muted mt-1">{previousDate}</div>
          </div>
          <svg class="w-4 h-4 text-text-muted group-hover:text-accent-deep group-hover:translate-x-1 transition-all shrink-0 self-center" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      )}

      <!-- Hinweis unter der Card -->
      <p class="text-center text-xs font-mono text-text-muted mt-6">
        Erscheint jeden Freitag · <a href="/briefing/feed.xml" class="underline hover:text-text-primary">RSS</a>
      </p>
    </div>
  </div>
</section>

<style>
  a.block.paper-elevated {
    text-decoration: none;
    color: inherit;
  }
  a.prev-briefing {
    text-decoration: none;
    color: inherit;
  }
</style>
