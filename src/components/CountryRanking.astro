---
/**
 * Country AI Power Rankings — based on multiple indicators
 * Data approximated from Stanford AI Index 2026, Tortoise Global AI Index
 */

interface Country {
  rank: number;
  code: string;
  name: string;
  flag: string;
  overall: number;
  metrics: { compute: number; talent: number; papers: number; funding: number; labs: number };
  topLabs: string[];
  note: string;
}

const countries: Country[] = [
  {
    rank: 1,
    code: 'US',
    name: 'USA',
    flag: '🇺🇸',
    overall: 97,
    metrics: { compute: 98, talent: 95, papers: 92, funding: 99, labs: 98 },
    topLabs: ['OpenAI', 'Anthropic', 'Google DeepMind', 'Meta AI', 'xAI'],
    note: 'Uneinholbar bei Frontier-Compute, Kapital und Talenten. 5 der 6 führenden Labs.',
  },
  {
    rank: 2,
    code: 'CN',
    name: 'China',
    flag: '🇨🇳',
    overall: 78,
    metrics: { compute: 72, talent: 85, papers: 95, funding: 82, labs: 78 },
    topLabs: ['DeepSeek', 'Z.ai (Zhipu)', 'Baidu ERNIE', 'Alibaba Qwen', 'Tencent Hunyuan'],
    note: 'Führt bei Papers. Holt rasant bei Open-Source-Models auf (DeepSeek R1, GLM-5). Huawei Ascend reduziert Compute-Gap.',
  },
  {
    rank: 3,
    code: 'UK',
    name: 'UK',
    flag: '🇬🇧',
    overall: 62,
    metrics: { compute: 55, talent: 82, papers: 78, funding: 58, labs: 68 },
    topLabs: ['DeepMind (Google)', 'Isomorphic Labs', 'PolyAI', 'Wayve'],
    note: 'DeepMind-Hauptsitz. AISI führend bei Governance. Isomorphic Labs ($600M, Hassabis) Pharma-Pionier.',
  },
  {
    rank: 4,
    code: 'EU',
    name: 'EU',
    flag: '🇪🇺',
    overall: 54,
    metrics: { compute: 42, talent: 72, papers: 68, funding: 38, labs: 58 },
    topLabs: ['Mistral (FR)', 'DeepL (DE)', 'Aleph Alpha (DE)', 'Silo AI (FI)'],
    note: 'Starke Grundlagenforschung, schwache Skalierung. AI Act setzt Standards, hemmt aber Investitionen. Frankreich mit Mistral der stärkste Einzelstandort.',
  },
  {
    rank: 5,
    code: 'CA',
    name: 'Kanada',
    flag: '🇨🇦',
    overall: 52,
    metrics: { compute: 42, talent: 78, papers: 72, funding: 45, labs: 48 },
    topLabs: ['Cohere', 'MILA', 'Vector Institute'],
    note: 'Hinton (Toronto) und Bengio (MILA Montréal) — weltweit in Top-5 Talent-Pools. C$925M Compute-Fund 2025-26 erweitert Kapazität.',
  },
  {
    rank: 6,
    code: 'KR',
    name: 'Südkorea',
    flag: '🇰🇷',
    overall: 52,
    metrics: { compute: 48, talent: 68, papers: 58, funding: 55, labs: 45 },
    topLabs: ['Naver HyperCLOVA', 'LG Exaone 4', 'Upstage Solar Pro'],
    note: 'Sovereign-AI-Strategie mit $735B-Initiative. Naver und LG mit eigenen Frontier-LLMs. Chip-Kapazität durch Samsung/SK Hynix.',
  },
  {
    rank: 7,
    code: 'IL',
    name: 'Israel',
    flag: '🇮🇱',
    overall: 42,
    metrics: { compute: 32, talent: 65, papers: 48, funding: 48, labs: 38 },
    topLabs: ['AI21 Labs', 'Run:ai', 'D-ID'],
    note: 'Überproportionale Startup-Dichte pro Kopf. Verteidigungs-KI global führend.',
  },
  {
    rank: 8,
    code: 'JP',
    name: 'Japan',
    flag: '🇯🇵',
    overall: 34,
    metrics: { compute: 35, talent: 42, papers: 35, funding: 28, labs: 30 },
    topLabs: ['Sakana AI', 'Preferred Networks', 'NTT AI'],
    note: 'Stark in Robotik-KI und Embodied-AI. Struggles bei LLM-Frontier.',
  },
  {
    rank: 9,
    code: 'DE',
    name: 'Deutschland',
    flag: '🇩🇪',
    overall: 32,
    metrics: { compute: 28, talent: 55, papers: 48, funding: 22, labs: 25 },
    topLabs: ['Aleph Alpha', 'DeepL', 'Fraunhofer'],
    note: 'Innerhalb EU der stärkste Einzelstandort. Industrie-KI und Sprachtechnologie-Fokus.',
  },
];

const getColor = (rank: number) => {
  if (rank === 1) return '#8b2c4d';
  if (rank === 2) return '#5b3aa3';
  if (rank <= 4) return '#b8721c';
  return '#7a705e';
};

const metricLabels: Record<string, string> = {
  compute: 'Compute',
  talent: 'Talent',
  papers: 'Papers',
  funding: 'Funding',
  labs: 'Labs',
};
---

<section id="countries" class="relative py-20 md:py-28">
  <div class="section-container">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="badge mx-auto mb-6">
        <span class="w-1 h-1 rounded-full bg-accent"></span>
        Global AI Race
      </div>
      <h2 class="font-display font-normal text-balance leading-[1.05] text-[clamp(1.875rem,6vw,5rem)] mb-6">
        Das <em class="italic gradient-text">Ranking</em>
      </h2>
      <p class="text-text-primary text-lg md:text-xl leading-relaxed font-medium">
        Wer führt im globalen AI-Rennen? Acht Nationen, fünf Indikatoren.
      </p>
    </div>

    <!-- Top 3 Podium -->
    <div class="grid grid-cols-3 gap-4 md:gap-6 mb-12 max-w-4xl mx-auto">
      {[2, 1, 3].map((pos) => {
        const c = countries.find((x) => x.rank === pos)!;
        const heights = { 1: 'h-48', 2: 'h-36', 3: 'h-32' };
        return (
          <div class="flex flex-col items-center">
            <div class="text-5xl mb-3">{c.flag}</div>
            <div class="font-display text-2xl text-text-primary mb-1">{c.name}</div>
            <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-2">
              Rang {c.rank}
            </div>
            <div class="font-display text-4xl tabular-nums mb-3" style={`color: ${getColor(c.rank)};`}>
              {c.overall}
            </div>
            <div
              class={`w-full rounded-t-2xl flex items-center justify-center text-white font-display text-3xl ${heights[c.rank as keyof typeof heights]}`}
              style={`background: ${getColor(c.rank)};`}
            >
              {c.rank === 1 ? '🥇' : c.rank === 2 ? '🥈' : '🥉'}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Full ranking table -->
    <div class="space-y-3">
      {countries.map((c) => (
        <article class="paper-elevated rounded-2xl p-6 md:p-8 group hover:bg-bg-card-hover transition-all">
          <div class="grid grid-cols-[auto_1fr] md:grid-cols-[auto_auto_1fr_auto] gap-6 items-start">
            <!-- Rank + Flag -->
            <div class="flex items-center gap-4">
              <div class="font-display text-4xl tabular-nums" style={`color: ${getColor(c.rank)};`}>
                {String(c.rank).padStart(2, '0')}
              </div>
              <div class="text-4xl">{c.flag}</div>
            </div>

            <!-- Name & Overall -->
            <div class="md:border-r md:border-border md:pr-6">
              <h3 class="font-display text-2xl md:text-3xl text-text-primary leading-tight">{c.name}</h3>
              <div class="flex items-baseline gap-1 mt-1">
                <span class="font-display text-2xl tabular-nums" style={`color: ${getColor(c.rank)};`}>
                  {c.overall}
                </span>
                <span class="text-xs font-mono text-text-muted">/100</span>
              </div>
            </div>

            <!-- Metrics bars -->
            <div class="col-span-2 md:col-span-1 space-y-2">
              {Object.entries(c.metrics).map(([key, val]) => (
                <div class="grid grid-cols-[70px_1fr_32px] items-center gap-3 text-xs">
                  <span class="font-mono uppercase tracking-wider text-text-muted">{metricLabels[key]}</span>
                  <div class="h-1.5 bg-bg-tertiary rounded-full overflow-hidden">
                    <div
                      class="h-full rounded-full"
                      style={`width: ${val}%; background: ${getColor(c.rank)};`}
                    ></div>
                  </div>
                  <span class="font-mono tabular-nums text-text-primary text-right">{val}</span>
                </div>
              ))}
            </div>

            <!-- Top Labs -->
            <div class="col-span-2 md:col-span-1 md:text-right">
              <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-2">
                Top Labs
              </div>
              <div class="flex flex-wrap gap-1.5 md:justify-end">
                {c.topLabs.slice(0, 3).map((lab) => (
                  <span class="text-[11px] font-mono px-2 py-0.5 rounded-md bg-bg-secondary text-text-secondary">
                    {lab}
                  </span>
                ))}
              </div>
            </div>
          </div>
          <p class="text-sm text-text-secondary leading-relaxed mt-4 pt-4 border-t border-border">
            {c.note}
          </p>
        </article>
      ))}
    </div>

    <!-- Methodik-Accordion -->
    <div class="max-w-4xl mx-auto mt-12">
      <details class="paper-elevated rounded-3xl overflow-hidden group">
        <summary class="list-none cursor-pointer p-7 md:p-9 flex items-center gap-5 hover:bg-bg-card-hover transition-colors">
          <div class="shrink-0 w-10 h-10 rounded-xl bg-bg-ink text-bg-primary flex items-center justify-center">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m-6 4h6m-6 4h4m3-14H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z"/>
            </svg>
          </div>
          <div class="flex-1">
            <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-1">Methodik</div>
            <h3 class="font-display text-xl md:text-2xl text-text-primary leading-tight">
              Wie kommt der Länder-Score zustande?
            </h3>
            <p class="text-sm text-text-secondary mt-1">Formel, Gewichtungen, Quellen.</p>
          </div>
          <svg class="w-5 h-5 text-text-muted group-open:rotate-180 transition-transform duration-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="px-7 md:px-9 pb-9 space-y-6 text-[14px] text-text-secondary leading-relaxed">
          <div>
            <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-3">Formel</div>
            <div class="paper rounded-2xl p-5 font-mono text-sm text-text-primary">
              overall = 0.30·Compute + 0.25·Talent + 0.20·Papers + 0.15·Funding + 0.10·Labs
            </div>
          </div>
          <div>
            <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-3">Gewichtung &amp; was sie misst</div>
            <ul class="space-y-2 text-[13px]">
              <li><strong class="text-text-primary">Compute (30%)</strong> — installierte Frontier-Trainings-FLOPs, Hyperscaler-Kapazität pro Land. Härtester Moat.</li>
              <li><strong class="text-text-primary">Talent (25%)</strong> — aktive AI-Forscher mit Top-Tier-Publications, gewichtet nach PhD-Output.</li>
              <li><strong class="text-text-primary">Papers (20%)</strong> — ArXiv-cs.AI-Volumen plus Citation-Index (Top-10%-Papers).</li>
              <li><strong class="text-text-primary">Funding (15%)</strong> — Venture- + staatliche AI-Investitionen in lokale Labs/Startups.</li>
              <li><strong class="text-text-primary">Labs (10%)</strong> — Anzahl aktiver Frontier-Labs mit Produkt-Release (SOTA oder nahe SOTA).</li>
            </ul>
          </div>
          <div>
            <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-3">Primärquellen</div>
            <ul class="space-y-1 text-[13px]">
              <li>· <a href="https://hai.stanford.edu/ai-index/2026-ai-index-report" target="_blank" rel="noopener noreferrer" class="text-accent-deep hover:underline">Stanford AI Index 2026</a> — Compute, Talent, Papers-Daten</li>
              <li>· <a href="https://www.tortoisemedia.com/intelligence/global-ai/" target="_blank" rel="noopener noreferrer" class="text-accent-deep hover:underline">Tortoise Global AI Index</a> — Länder-Gewichtungsreferenz</li>
              <li>· <a href="https://epoch.ai" target="_blank" rel="noopener noreferrer" class="text-accent-deep hover:underline">Epoch AI</a> — Compute-Dimensionen, Trainings-FLOPs-Tracking</li>
            </ul>
          </div>
          <p class="text-xs font-mono text-text-muted italic leading-relaxed">
            Update-Rhythmus: quartalsweise. Werte normalisiert auf 0–100 pro Indikator, dann gewichtet aggregiert.
          </p>
        </div>
      </details>
    </div>
  </div>
</section>
