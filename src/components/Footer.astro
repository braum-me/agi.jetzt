---
// Build-Zeit (einmalig zur Deploy-Zeit gesetzt)
const buildTime = new Date();
const timestamp = buildTime.toLocaleDateString('de-DE', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
});
---

<footer class="relative pt-24 pb-10 overflow-hidden border-t border-border">
  <!-- Big logo bg watermark -->
  <div class="absolute inset-0 flex items-end justify-center pointer-events-none overflow-hidden">
    <h2 class="font-display text-[clamp(8rem,30vw,30rem)] leading-[0.85] text-text-primary opacity-[0.03] translate-y-[20%] tracking-tighter italic">
      agi.jetzt
    </h2>
  </div>

  <div class="section-container relative">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
      <div class="md:col-span-2">
        <a href="/" class="inline-flex items-center gap-2.5 font-display text-2xl mb-4">
          <span class="relative flex items-center justify-center w-9 h-9 rounded-full bg-bg-ink">
            <svg class="w-5 h-5 text-bg-primary" fill="none" viewBox="0 0 24 24">
              <path d="M9 7c0-1.1.9-2 2-2h2c1.1 0 2 .9 2 2v2.5M9 7v2.5M9 7c-1.1 0-2 .9-2 2v2c0 1.1.9 2 2 2M15 9.5V12c0 1.1-.9 2-2 2M15 9.5c1.1 0 2 .9 2 2s-.9 2-2 2M9 12c0 1.1.9 2 2 2v3M9 12v3M11 17c0 1.1.9 2 2 2h0c1.1 0 2-.9 2-2v-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="12" cy="12" r="0.8" fill="currentColor"/>
            </svg>
          </span>
          <span class="text-text-primary">agi<span class="text-text-muted">.</span><span class="italic">jetzt</span></span>
        </a>
        <p class="text-text-secondary text-base leading-relaxed max-w-md font-display italic">
          "Eine Seite, die dokumentiert, was passiert — während es passiert."
        </p>
      </div>

      <div>
        <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-4">
          Navigation
        </div>
        <nav class="grid grid-cols-2 gap-y-2 gap-x-6 text-sm">
          <a href="/" class="footer-link text-text-secondary hover:text-text-primary transition-colors">Übersicht</a>
          <a href="/dashboard" class="footer-link text-text-secondary hover:text-text-primary transition-colors">Dashboard</a>
          <a href="/briefing" class="footer-link text-text-secondary hover:text-text-primary transition-colors">Briefing</a>
          <a href="/geschichte" class="footer-link text-text-secondary hover:text-text-primary transition-colors">Chronik</a>
          <a href="/kapital" class="footer-link text-text-secondary hover:text-text-primary transition-colors">Kapital</a>
          <a href="/laender" class="footer-link text-text-secondary hover:text-text-primary transition-colors">Wettlauf</a>
          <a href="/compute" class="footer-link text-text-secondary hover:text-text-primary transition-colors">Compute</a>
          <a href="/kontroversen" class="footer-link text-text-secondary hover:text-text-primary transition-colors">Debatten</a>
          <a href="/glossar" class="footer-link text-text-secondary hover:text-text-primary transition-colors">Glossar</a>
          <a href="/methodik" class="footer-link text-text-secondary hover:text-text-primary transition-colors">Methodik</a>
        </nav>
      </div>
    </div>

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 pt-8 border-t border-border text-xs text-text-muted">
      <p>
        &copy; 2026 Stefan Braum ·
        <a href="https://braum.consulting" target="_blank" rel="noopener noreferrer" class="footer-link hover:text-text-primary transition-colors">Braum Consulting</a>
      </p>

      <div class="flex items-center gap-5 flex-wrap">
        <a href="/impressum/" class="footer-link hover:text-text-primary transition-colors">
          Impressum
        </a>
        <a href="/datenschutz/" class="footer-link hover:text-text-primary transition-colors">
          Datenschutz
        </a>
        <a href="https://github.com/braum-me" target="_blank" rel="noopener noreferrer" class="footer-link hover:text-text-primary transition-colors inline-flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.04-.01-2.05-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.23 1.84 1.23 1.07 1.83 2.81 1.3 3.5.99.11-.77.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.23-3.22-.12-.3-.54-1.52.12-3.17 0 0 1.01-.32 3.3 1.23a11.52 11.52 0 016 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.65.25 2.87.12 3.17.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.93.43.37.81 1.1.81 2.22 0 1.61-.01 2.9-.01 3.3 0 .32.22.7.83.58C20.56 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <a href="https://linkedin.com/in/stefanbraum" target="_blank" rel="noopener noreferrer" class="footer-link hover:text-text-primary transition-colors inline-flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <span class="hidden md:inline">·</span>
        <span class="hidden md:inline font-mono">Aktualisiert {timestamp}</span>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Editorial underline-slide auf Hover — greift auf alle .footer-link */
  .footer-link {
    position: relative;
    display: inline-flex;
  }
  .footer-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    height: 1px;
    width: 0;
    background: currentColor;
    opacity: 0.6;
    transition: width 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .footer-link:hover::after,
  .footer-link:focus-visible::after {
    width: 100%;
  }
</style>
