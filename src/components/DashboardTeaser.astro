---
import statsData from '../data/dashboard/stats.json';
import companies from '../data/dashboard/companies.json';

// 3 Key-Stats für Landing
const fmt = (v: number): string => {
  if (v >= 1_000_000) return (v / 1_000_000).toFixed(1).replace(/\.0$/, '') + 'M';
  if (v >= 1_000) return (v / 1_000).toFixed(1).replace(/\.0$/, '') + 'k';
  return v.toLocaleString('de-DE');
};

const teaserStats = [
  {
    label: 'AGI Proximity',
    value: statsData.kpis.find((k) => k.key === 'agi_score')?.value ?? 66,
    suffix: '/100',
    desc: '8 Benchmark-Gaps, geometrisches Mittel',
  },
  {
    label: 'Frontier-Modelle',
    value: statsData.kpis.find((k) => k.key === 'frontier_models')?.value ?? 12,
    suffix: '',
    desc: 'aktiv mit ≥10²⁶ FLOPs',
  },
  {
    label: 'Total Funding 2025',
    value: '$' + (statsData.kpis.find((k) => k.key === 'ai_funding_2025')?.value ?? 163.6),
    suffix: 'B',
    desc: 'Investments laut Crunchbase + Dealroom',
  },
];

const topCompanies = companies.companies.slice(0, 3);
---

<section id="dashboard-teaser" class="relative py-16 md:py-24">
  <div class="section-container">
    <div class="max-w-5xl mx-auto">
      <!-- Header -->
      <div class="flex items-end justify-between gap-4 mb-8 flex-wrap">
        <div>
          <div class="badge mb-3">
            <span class="w-1 h-1 rounded-full bg-accent"></span>
            Live-Daten
          </div>
          <h2 class="font-display font-normal text-balance leading-[1.05] text-[clamp(1.75rem,4.5vw,3.5rem)]">
            Alle Daten im <em class="italic gradient-text">Dashboard</em>
          </h2>
        </div>
        <a
          href="/dashboard"
          class="text-sm font-mono text-text-muted hover:text-text-primary transition-colors inline-flex items-center gap-1.5"
        >
          Zum Dashboard
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <!-- 3 Key-Stats -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 mb-6">
        {teaserStats.map((s) => (
          <div class="paper-elevated rounded-2xl p-6">
            <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-2">
              {s.label}
            </div>
            <div class="flex items-baseline gap-1 mb-2">
              <span class="font-display text-4xl tabular-nums text-text-primary">
                {s.value}
              </span>
              {s.suffix && <span class="text-lg text-text-muted">{s.suffix}</span>}
            </div>
            <p class="text-[11px] text-text-muted leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>

      <!-- Mini-Leaderboard Tease -->
      <a
        href="/dashboard"
        class="block group paper-elevated rounded-2xl p-6 hover:bg-bg-card-hover transition-all no-underline"
      >
        <div class="flex items-center justify-between gap-4 mb-4">
          <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted">
            Top 3 Unternehmen nach Valuation
          </div>
          <span class="text-xs font-mono text-text-muted group-hover:text-accent-deep transition-colors">
            +12 mehr im Dashboard →
          </span>
        </div>
        <div class="grid grid-cols-3 gap-4">
          {topCompanies.map((c) => (
            <div>
              <div class="font-display text-xl text-text-primary mb-0.5 group-hover:text-accent-deep transition-colors">
                {c.name}
              </div>
              <div class="font-mono text-sm tabular-nums" style="color: var(--color-accent-deep);">
                ${c.valuation}B
              </div>
              <div class="text-[10px] text-text-muted">{c.category}</div>
            </div>
          ))}
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  a.block.paper-elevated {
    text-decoration: none;
    color: inherit;
  }
</style>
