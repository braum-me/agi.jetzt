---
import WidgetCard from '../WidgetCard.astro';
import data from '../../../data/dashboard/funding-breakdown.json';
---

<WidgetCard
  title="Funding Breakdown"
  subtitle={`Jahr 2025 · $${data.total_2025_bn} Mrd gesamt`}
  stand={data.stand}
  source={data.source}
  size="md"
  span="md:col-span-4"
>
  <div id="funding-chart" style="width: 100%; height: 260px;"></div>
  <div class="mt-3 space-y-1">
    {data.categories.map((c) => (
      <div class="flex items-center gap-2 text-xs">
        <span class="w-2.5 h-2.5 rounded-sm shrink-0" style={`background: ${c.color};`}></span>
        <span class="text-text-primary flex-1 truncate">{c.name}</span>
        <span class="font-mono tabular-nums text-text-muted">${c.value} Mrd</span>
        <span class="font-mono text-accent-deep shrink-0">{c.pct}%</span>
      </div>
    ))}
  </div>
</WidgetCard>

<script>
  import data from '../../../data/dashboard/funding-breakdown.json';

  const el = document.getElementById('funding-chart');
  if (el) {
    const io = new IntersectionObserver(async (entries) => {
      if (!entries.some((e) => e.isIntersecting)) return;
      io.disconnect();
      const { mountChart } = await import('../../../scripts/dashboard/charts');
      mountChart(el, {
        tooltip: {
          trigger: 'item',
          formatter: (p: any) => `<strong>${p.name}</strong><br/>$${p.value} Mrd · ${p.percent.toFixed(0)}%`,
        },
        series: [{
          type: 'pie',
          radius: ['60%', '85%'],
          center: ['50%', '50%'],
          avoidLabelOverlap: true,
          itemStyle: { borderRadius: 2, borderColor: '#f5f1e8', borderWidth: 2 },
          label: { show: false },
          emphasis: { label: { show: false }, scale: true, scaleSize: 6 },
          data: data.categories.map((c) => ({
            name: c.name, value: c.value, itemStyle: { color: c.color },
          })),
        }],
      });
    }, { rootMargin: '200px' });
    io.observe(el);
  }
</script>
