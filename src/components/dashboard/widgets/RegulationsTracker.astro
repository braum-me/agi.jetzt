---
import WidgetCard from '../WidgetCard.astro';
import data from '../../../data/dashboard/regulations.json';

const statusColor: Record<string, string> = {
  in_force: 'text-forest',
  voluntary: 'text-accent-deep',
  pending: 'text-amber',
};
const statusDot: Record<string, string> = {
  in_force: 'bg-forest',
  voluntary: 'bg-accent',
  pending: 'bg-amber',
};
---

<WidgetCard
  title="Regulations Tracker"
  subtitle="Globale AI-Regulierung auf einen Blick"
  stand={data.stand}
  source={data.source}
  size="md"
  span="md:col-span-4"
  moreLink="/kontroversen"
  moreLinkLabel="Die Debatten"
>
  <div class="space-y-2.5 max-h-[420px] overflow-y-auto pr-1">
    {data.items.map((r) => (
      <a
        href={r.url}
        target="_blank"
        rel="noopener noreferrer"
        class="block p-2.5 rounded-lg hover:bg-bg-card-hover transition-colors border border-border/60"
      >
        <div class="flex items-start justify-between gap-3 mb-1">
          <div class="flex items-center gap-2 min-w-0">
            <span class="text-base leading-none shrink-0">{r.flag}</span>
            <span class="font-medium text-text-primary text-xs truncate">{r.name}</span>
          </div>
          <span class={`flex items-center gap-1 text-[10px] font-mono uppercase tracking-wider shrink-0 ${statusColor[r.status]}`}>
            <span class={`w-1.5 h-1.5 rounded-full ${statusDot[r.status]}`}></span>
            {r.status_label}
          </span>
        </div>
        <div class="text-[10px] font-mono text-text-muted mb-1">
          {r.region} · {r.since}
        </div>
        <p class="text-xs text-text-secondary leading-relaxed line-clamp-2">
          {r.description}
        </p>
      </a>
    ))}
  </div>
</WidgetCard>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
