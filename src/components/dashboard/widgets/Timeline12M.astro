---
import WidgetCard from '../WidgetCard.astro';
import data from '../../../data/dashboard/timeline-12m.json';

const catColor: Record<string, string> = {
  release: '#5b3aa3',
  regulation: '#b8721c',
  benchmark: '#8b2c4d',
  infrastructure: '#2d5a3f',
};
---

<WidgetCard
  anchor="timeline"
  title="Timeline — 12 Monate"
  subtitle={data.window}
  stand={data.stand}
  source={data.source}
  size="md"
  span="col-span-12"
>
  <div class="overflow-x-auto pb-2">
    <div class="relative flex gap-3 min-w-max px-2" style="min-height: 220px;">
      <!-- Connecting horizontal line -->
      <div class="absolute left-0 right-0 top-16 h-px bg-border-strong pointer-events-none"></div>

      {data.events.map((e) => (
        <div class="relative flex flex-col items-center shrink-0" style="width: 170px;">
          <!-- Dot on line -->
          <div class="relative" style="margin-top: 3.5rem;">
            <div
              class="w-3 h-3 rounded-full ring-4 ring-bg-primary"
              style={`background: ${catColor[e.category]};`}
            ></div>
          </div>
          <div class="mt-3 text-center">
            <div class="text-[10px] font-mono text-text-muted mb-1">
              {e.date}
            </div>
            <div class="text-xs text-text-primary font-medium leading-snug mb-1 line-clamp-2">
              {e.title}
            </div>
            <div class="text-[10px] font-mono uppercase tracking-wider" style={`color: ${catColor[e.category]};`}>
              {e.org}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Legend -->
  <div class="flex flex-wrap gap-4 mt-4 pt-3 border-t border-border text-xs">
    {Object.entries(catColor).map(([cat, color]) => (
      <span class="inline-flex items-center gap-1.5">
        <span class="w-2 h-2 rounded-full" style={`background: ${color};`}></span>
        <span class="text-text-secondary capitalize">{cat}</span>
      </span>
    ))}
  </div>
</WidgetCard>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
