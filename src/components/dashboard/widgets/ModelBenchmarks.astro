---
import WidgetCard from '../WidgetCard.astro';
import data from '../../../data/dashboard/benchmarks.json';
---

<WidgetCard
  anchor="models"
  title="Model Benchmarks"
  subtitle="Radar über 6 Kern-Benchmarks"
  stand={data.stand}
  source={data.source}
  sourceUrl={data.source_url}
  size="lg"
  span="md:col-span-5"
>
  <div id="benchmarks-chart" style="width: 100%; height: 340px;"></div>
  <div class="mt-3 flex flex-wrap gap-3 text-xs">
    {data.models.map((m) => (
      <span class="inline-flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full" style={`background: ${m.color};`}></span>
        <span class="text-text-secondary">{m.name}</span>
      </span>
    ))}
  </div>
</WidgetCard>

<script>
  import data from '../../../data/dashboard/benchmarks.json';

  const el = document.getElementById('benchmarks-chart');
  if (el) {
    const io = new IntersectionObserver(async (entries) => {
      if (!entries.some((e) => e.isIntersecting)) return;
      io.disconnect();
      const { mountChart, chartTheme } = await import('../../../scripts/dashboard/charts');
      mountChart(el, {
        tooltip: { trigger: 'item' },
        radar: {
          indicator: data.benchmarks.map((b) => ({ name: b, max: 100 })),
          splitArea: { show: false },
          splitLine: { lineStyle: { color: chartTheme.grid, opacity: 0.3 } },
          axisLine: { lineStyle: { color: chartTheme.grid, opacity: 0.3 } },
          axisName: {
            color: chartTheme.textMuted,
            fontFamily: 'JetBrains Mono',
            fontSize: 10,
          },
          center: ['50%', '52%'],
          radius: '68%',
        },
        series: [{
          type: 'radar',
          data: data.models.map((m) => ({
            name: m.name,
            value: m.scores,
            lineStyle: { color: m.color, width: 2 },
            itemStyle: { color: m.color },
            areaStyle: { color: m.color, opacity: 0.08 },
            symbol: 'circle',
            symbolSize: 5,
          })),
        }],
      });
    }, { rootMargin: '200px' });
    io.observe(el);
  }
</script>
