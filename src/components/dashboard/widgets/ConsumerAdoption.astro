---
import WidgetCard from '../WidgetCard.astro';
import data from '../../../data/dashboard/adoption.json';
---

<WidgetCard
  anchor="adoption"
  title="Consumer Adoption"
  subtitle="Quartalsweise bestätigte Snapshots · WAU bzw. MAU"
  stand={data.stand}
  source={data.source}
  size="md"
  span="md:col-span-5"
>
  <div id="adoption-chart" style="width: 100%; height: 320px;"></div>

  <!-- Kontext: passive AI-Overviews-Nutzung in Search -->
  <div class="mt-4 paper rounded-xl px-4 py-3 flex items-start gap-3">
    <span class="font-display text-xl text-burgundy tabular-nums leading-none shrink-0">2 Mrd.</span>
    <div class="text-[11px] text-text-secondary leading-relaxed">
      <strong class="text-text-primary">Google AI Overviews</strong> erreicht zusätzlich monatlich Milliarden Search-Nutzer
      <em>passiv</em> — eigene Kategorie, würde im Chart alle anderen erschlagen.
      Wer Google nur über AI-Overviews in der Suche sieht, ist NICHT in der Gemini-App-Linie.
      <a href="https://techcrunch.com/2025/07/23/googles-ai-overviews-have-2b-monthly-users-ai-mode-100m-in-the-us-and-india/" target="_blank" rel="noopener noreferrer" class="text-accent-deep hover:underline">TechCrunch ↗</a>
    </div>
  </div>

  <!-- Caveat -->
  <p class="mt-3 text-[11px] text-text-muted italic leading-relaxed">
    Datenpunkte = quartalsweise Earnings/PR-Statements. Keine geglätteten Monatsverläufe — alles dazwischen wäre erfundene Präzision. Q1 2026 noch nicht bestätigt (außer ChatGPT/Gemini per Februar-Earnings).
  </p>

  <details class="mt-4 group">
    <summary class="list-none cursor-pointer flex items-center gap-2 text-[10px] font-mono uppercase tracking-[0.2em] text-text-muted hover:text-text-primary transition-colors">
      <svg class="w-3 h-3 group-open:rotate-90 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
      </svg>
      Quellen je Produkt
    </summary>
    <div class="mt-3 space-y-3">
      <p class="text-[11px] text-text-secondary leading-relaxed italic">{data.note}</p>
      {data.products.map((p) => (
        <div class="text-[11px]">
          <div class="flex items-center gap-2 mb-1">
            <span class="w-2 h-2 rounded-full shrink-0" style={`background: ${p.color};`}></span>
            <span class="font-medium text-text-primary">{p.name}</span>
          </div>
          <ul class="pl-4 space-y-0.5">
            {p.sources?.map((s: any) => (
              <li>
                <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent-deep transition-colors underline-offset-2 hover:underline">
                  {s.label} ↗
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </details>
</WidgetCard>

<script>
  import data from '../../../data/dashboard/adoption.json';

  const el = document.getElementById('adoption-chart');
  if (el) {
    const io = new IntersectionObserver(async (entries) => {
      if (!entries.some((e) => e.isIntersecting)) return;
      io.disconnect();
      const { mountChart, chartTheme } = await import('../../../scripts/dashboard/charts');
      mountChart(el, {
        tooltip: {
          trigger: 'axis',
          confine: true,
          appendToBody: true,
          extraCssText: 'max-width: 340px; white-space: normal; z-index: 200;',
          formatter: (params: any[]) => {
            const q = params[0]?.axisValue || '';
            const lines = params.map((p) => {
              const product = (data.products as any[]).find((x) => x.name === p.seriesName);
              const idx = p.dataIndex;
              const note = product?.valueNotes?.[idx] ?? '';
              return `<div style="display:flex;align-items:center;gap:6px;margin:2px 0;"><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${p.color};"></span><strong>${p.seriesName}</strong>: ${p.value}M${note ? ` <span style="opacity:.6;font-size:11px;">— ${note}</span>` : ''}</div>`;
            }).join('');
            return `<div style="font-family:JetBrains Mono,monospace;font-size:11px;">${q}</div>${lines}`;
          },
        },
        legend: {
          bottom: 0,
          textStyle: { color: chartTheme.textMuted, fontFamily: 'JetBrains Mono', fontSize: 10 },
          itemWidth: 12, itemHeight: 8,
        },
        grid: { left: 40, right: 20, top: 10, bottom: 40, containLabel: true },
        xAxis: {
          type: 'category',
          data: data.quarters,
          boundaryGap: false,
          axisLine: { lineStyle: { color: chartTheme.grid } },
          axisLabel: { color: chartTheme.textMuted, fontFamily: 'JetBrains Mono', fontSize: 10 },
        },
        yAxis: {
          type: 'value',
          axisLine: { show: false },
          axisLabel: { color: chartTheme.textMuted, fontFamily: 'JetBrains Mono', fontSize: 10, formatter: '{value}M' },
          axisTick: { show: false },
          splitLine: { lineStyle: { color: chartTheme.grid, opacity: 0.3, type: 'dashed' } },
        },
        series: data.products.map((p: any) => ({
          name: p.name,
          type: 'line',
          smooth: false,
          symbol: 'circle',
          symbolSize: 7,
          lineStyle: { color: p.color, width: 2 },
          itemStyle: { color: p.color, borderColor: '#fff', borderWidth: 1.5 },
          data: p.values,
          emphasis: { focus: 'series', scale: 1.4 },
        })),
      });
    }, { rootMargin: '200px' });
    io.observe(el);
  }
</script>
