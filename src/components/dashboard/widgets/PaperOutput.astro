---
import WidgetCard from '../WidgetCard.astro';
import data from '../../../data/dashboard/papers.json';
---

<WidgetCard
  anchor="research"
  title="ArXiv Papers (cs.AI)"
  subtitle={`Monatliche Submissions · aktuell ${data.counts[data.counts.length - 1].toLocaleString('de-DE')}/Monat`}
  stand={data.stand}
  source={data.source}
  size="md"
  span="md:col-span-4"
>
  <div id="papers-chart" style="width: 100%; height: 260px;"></div>
</WidgetCard>

<script>
  import data from '../../../data/dashboard/papers.json';

  const el = document.getElementById('papers-chart');
  if (el) {
    const io = new IntersectionObserver(async (entries) => {
      if (!entries.some((e) => e.isIntersecting)) return;
      io.disconnect();
      const { mountChart, chartTheme } = await import('../../../scripts/dashboard/charts');

      const markLineData = data.key_releases.map((r) => ({
      name: r.label,
      xAxis: r.month,
      label: {
        formatter: r.label,
        color: chartTheme.burgundy,
        fontFamily: 'JetBrains Mono',
        fontSize: 9,
        position: 'insideEndTop',
      },
      lineStyle: { color: chartTheme.burgundy, opacity: 0.4, type: 'dashed', width: 1 },
      }));

      mountChart(el, {
        tooltip: {
          trigger: 'axis',
          valueFormatter: (v: number) => v.toLocaleString('de-DE'),
        },
        grid: { left: 40, right: 10, top: 15, bottom: 35, containLabel: true },
        xAxis: {
          type: 'category',
          data: data.months,
          axisLine: { lineStyle: { color: chartTheme.grid } },
          axisLabel: { color: chartTheme.textMuted, fontFamily: 'JetBrains Mono', fontSize: 9, interval: 2 },
        },
        yAxis: {
          type: 'value',
          axisLine: { show: false },
          axisLabel: {
            color: chartTheme.textMuted,
            fontFamily: 'JetBrains Mono',
            fontSize: 9,
            formatter: (v: number) => (v / 1000).toFixed(0) + 'k',
          },
          axisTick: { show: false },
          splitLine: { lineStyle: { color: chartTheme.grid, opacity: 0.3, type: 'dashed' } },
        },
        series: [{
          name: 'Papers',
          type: 'line',
          smooth: true,
          symbol: 'none',
          lineStyle: { color: chartTheme.accent, width: 2 },
          areaStyle: {
            color: {
              type: 'linear', x: 0, y: 0, x2: 0, y2: 1,
              colorStops: [
                { offset: 0, color: 'rgba(91, 58, 163, 0.25)' },
                { offset: 1, color: 'rgba(91, 58, 163, 0)' },
              ],
            },
          },
          data: data.counts,
          markLine: {
            symbol: 'none',
            data: markLineData,
            silent: true,
          },
        }],
      });
    }, { rootMargin: '200px' });
    io.observe(el);
  }
</script>
