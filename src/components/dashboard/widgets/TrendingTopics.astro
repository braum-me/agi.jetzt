---
import WidgetCard from '../WidgetCard.astro';
import data from '../../../data/dashboard/trends.json';

const maxCount = Math.max(...data.tags.map((t) => t.count));
const minSize = 11;
const maxSize = 26;

const trendIcon = (t: string) => t === 'up' ? '↑' : t === 'down' ? '↓' : '→';
const trendColor = (t: string) => t === 'up' ? '#2d5a3f' : t === 'down' ? '#8b2c4d' : '#6b614f';
---

<WidgetCard
  title="Trending Topics"
  subtitle="Häufigste Tags in ArXiv-Abstracts und News"
  stand={data.stand}
  source={data.source}
  size="md"
  span="md:col-span-4"
>
  <div class="flex flex-wrap gap-2 items-center justify-center py-4" style="min-height: 260px;">
    {data.tags.map((t) => {
      const size = minSize + ((t.count / maxCount) * (maxSize - minSize));
      return (
        <span
          class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full border border-border bg-bg-card hover:border-accent transition-colors cursor-default"
          style={`font-size: ${size}px; font-family: var(--font-display);`}
        >
          <span style={`color: ${trendColor(t.trend)};`}>{t.tag}</span>
          <span class="text-xs" style={`color: ${trendColor(t.trend)};`}>{trendIcon(t.trend)}</span>
        </span>
      );
    })}
  </div>
</WidgetCard>
