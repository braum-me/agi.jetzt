---
import ThreeHero from './ThreeHero.astro';
import CountdownUnit from './CountdownUnit.astro';
import newsItems from '../data/news.json';

const sortedNews = newsItems
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());

const latestNews = sortedNews.slice(0, 6);

const newestNewsDate = sortedNews[0]?.date ?? '';
const timestamp = newestNewsDate
  ? new Date(newestNewsDate).toLocaleDateString('de-DE', {
      day: '2-digit',
      month: '2-digit',
      year: 'numeric',
    })
  : '';
---

<section id="hero" class="relative min-h-screen flex flex-col overflow-hidden">
  <!-- Three.js Neural Mesh Background (within hero section) -->
  <ThreeHero />

  <!-- Subtle radial backdrop hinter Text für Kontrast -->
  <div
    class="absolute inset-0 pointer-events-none z-[1]"
    style="background: radial-gradient(ellipse 50% 45% at 50% 50%, rgba(245, 241, 232, 0.75) 0%, rgba(245, 241, 232, 0.4) 40%, transparent 75%);"
  ></div>

  <!-- Sehr subtiler bottom fade nur -->
  <div
    class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none z-[2]"
    style="background: linear-gradient(to top, var(--color-bg-primary), transparent);"
  ></div>

  <!-- Content -->
  <div class="relative z-10 flex-1 flex flex-col justify-center items-center section-container pt-32 md:pt-40 pb-16 text-center">

    <!-- Live Badge — perfectly centered -->
    <div class="badge badge-accent mb-10 mx-auto">
      <span class="relative flex h-1.5 w-1.5">
        <span class="absolute inline-flex h-full w-full rounded-full bg-burgundy opacity-75" style="animation: pulse-ring 2s cubic-bezier(0, 0, 0.2, 1) infinite;"></span>
        <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-burgundy"></span>
      </span>
      <span>News-Stand: {timestamp}</span>
    </div>

    <!-- Massive Headline -->
    <h1 class="font-display font-normal leading-[0.95] tracking-tight max-w-5xl mx-auto mb-10">
      <span class="block text-[clamp(2.25rem,9vw,8rem)] text-text-primary">
        Der Weg zur
      </span>
      <span class="block text-[clamp(2.25rem,9vw,8rem)] text-text-primary">
        <em class="font-display italic gradient-text not-italic">Allgemeinen</em> Intelligenz
      </span>
    </h1>

    <!-- Subline — fully centered, dark for contrast -->
    <p class="text-text-primary text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-14 font-medium">
      Kuratiertes Tracking der wichtigsten Technologierevolution unserer Zeit — News täglich, Dashboard quartalsweise.
    </p>

    <!-- AGI Countdown -->
    <div class="mb-14">
      <p class="text-center text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-5">
        ⌛ Metaculus-Prognose · Bis zur ersten AGI
      </p>
      <div class="flex items-center justify-center gap-2 md:gap-5" data-countdown>
        <CountdownUnit key="y" label="Jahre" digits={2} />
        <span class="text-text-dim text-2xl md:text-3xl font-display">·</span>
        <CountdownUnit key="d" label="Tage" digits={3} />
        <span class="text-text-dim text-2xl md:text-3xl font-display">·</span>
        <CountdownUnit key="h" label="Std" digits={2} />
        <span class="text-text-dim text-2xl md:text-3xl font-display hidden sm:inline">·</span>
        <CountdownUnit key="m" label="Min" digits={2} visible="hidden sm:flex" />
        <span class="text-text-dim text-2xl md:text-3xl font-display hidden md:inline">·</span>
        <CountdownUnit key="s" label="Sek" digits={2} visible="hidden md:flex" pulse />
      </div>
    </div>

    <!-- CTAs — high contrast buttons -->
    <div class="flex flex-wrap items-center justify-center gap-3 md:gap-4">
      <a href="#proximity" class="btn-primary">
        Wie nah sind wir?
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </a>
      <a href="/briefing" class="btn-secondary">
        Briefing lesen
      </a>
    </div>
  </div>

  <!-- News Ticker -->
  <div class="relative z-10 w-full overflow-hidden border-t border-border bg-bg-primary/90 backdrop-blur-sm">
    <div
      class="flex items-center gap-3 py-3 px-6 border-r border-border text-[10px] font-mono uppercase tracking-[0.15em] text-burgundy whitespace-nowrap absolute left-0 top-0 bottom-0 z-[2]"
      style="background: var(--color-bg-card);"
    >
      <span class="flex h-1.5 w-1.5 rounded-full bg-burgundy animate-blink"></span>
      Live Feed
    </div>
    <div class="news-ticker flex whitespace-nowrap py-3 pl-44">
      <div class="ticker-track flex gap-12 animate-ticker">
        {[...latestNews, ...latestNews].map((news: any) => (
          <span class="inline-flex items-center gap-3 text-sm">
            <span class="text-accent font-mono text-[10px] uppercase tracking-wider">{news.category}</span>
            <span class="text-text-secondary">{news.headline}</span>
            <span class="text-text-dim">·</span>
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-ticker {
    animation: ticker 70s linear infinite;
  }
  .news-ticker:hover .animate-ticker {
    animation-play-state: paused;
  }
</style>

<script>
  import { initAgiCountdown } from '../scripts/agi-countdown';
  initAgiCountdown();
</script>
