---
const stages = [
  {
    id: 'ani',
    label: 'ANI',
    title: 'Schwache KI',
    status: 'Heute',
    badgeClass: 'badge-forest',
    description: 'Spezialisiert auf eine einzelne Aufgabe — Schach spielen, Texte schreiben, Bilder erkennen. Kann nicht über ihren Trainingsbereich hinausdenken.',
    examples: ['ChatGPT', 'Midjourney', 'Tesla Autopilot', 'AlphaFold'],
    timeframe: 'In Produktion seit 2010',
    visual: 'simple',
    accent: 'forest',
    abilities: [
      'Sprache & Code auf Senior-Niveau',
      'Bilder und Video fast fotorealistisch',
      'Protein-Strukturen besser als Labore',
      'Millionen Tokens Kontext',
    ],
    stillMissing: 'Selbstständige Zielsetzung, echtes Transferlernen zwischen Domänen, langfristiges Planen über Tage.',
    humanAnalogy: 'Wie ein:e brillante:r Fachidiot:in — Weltklasse in einer Disziplin, hilflos außerhalb davon.',
  },
  {
    id: 'agi',
    label: 'AGI',
    title: 'Allgemeine KI',
    status: 'In Reichweite',
    badgeClass: 'badge-amber',
    description: 'Kann jede intellektuelle Aufgabe lösen, die ein Mensch lösen kann. Lernt selbständig, transferiert Wissen zwischen Domänen, plant über lange Zeiträume.',
    examples: ['Kandidaten: GPT-5.5', 'Claude Opus 4.7', 'Gemini 3.1 (kein Konsens)'],
    timeframe: 'Metaculus: ~Mitte 2030',
    visual: 'network',
    accent: 'accent',
    abilities: [
      'Forschung auf Doktorats-Niveau über alle Felder',
      'Autonome Agents über Wochen-Projekte',
      'Echte Generalisierung aus wenigen Beispielen',
      'Selbst-Korrektur und Meta-Reasoning',
    ],
    stillMissing: 'Self-Improvement Loop, verlässliches Kausal-Reasoning, Überleben in offenen Umgebungen ohne Supervision.',
    humanAnalogy: 'Wie ein:e begabte Generalist:in mit 5 Doktortiteln — versteht alles, lernt schnell, löst Neues.',
  },
  {
    id: 'asi',
    label: 'ASI',
    title: 'Superintelligenz',
    status: 'Theoretisch',
    badgeClass: 'badge-burgundy',
    description: 'Übertrifft die kollektive menschliche Intelligenz in allen Bereichen. Wäre fähig zu rekursiver Selbstverbesserung. Implikationen unkalkulierbar.',
    examples: ['Konzepte: Seed AI', 'Technological Singularity', 'Recursive Self-Improvement'],
    timeframe: 'Unbekannt — möglicherweise kurz nach AGI',
    visual: 'explosion',
    accent: 'burgundy',
    abilities: [
      'Durchbrüche in Physik, Bio, Mathematik im Tagestakt',
      'Rekursive Verbesserung der eigenen Architektur',
      'Strategisches Planen über Jahrzehnte hinweg',
      'Modelliert komplette Gesellschaften in Echtzeit',
    ],
    stillMissing: 'Wir wissen nicht, was wir nicht wissen — und das ist Teil des Problems.',
    humanAnalogy: 'Die Menschheit insgesamt ist zur Schimpansen-Truppe, die versucht eine Konzernübernahme zu verstehen.',
  },
];
---

<section id="stages" class="relative py-20 md:py-28 overflow-hidden">
  <div class="section-container relative">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="badge mb-6">
        <span class="w-1 h-1 rounded-full bg-accent"></span>
        Drei Stufen
      </div>
      <h2 class="font-display font-normal text-balance leading-[1.05] text-[clamp(1.875rem,6vw,5rem)] mb-6">
        Was eigentlich ist<br/>
        <em class="italic gradient-text">"künstliche Intelligenz"</em>?
      </h2>
      <p class="text-text-secondary text-lg md:text-xl leading-relaxed font-light">
        Die KI von heute, AGI als nächster Schritt, und ASI als das Unbekannte dahinter.
      </p>
    </div>

    <!-- Connecting SVG path between stages (desktop only) -->
    <div class="hidden md:block absolute inset-x-0 pointer-events-none" style="top: 50%; transform: translateY(-50%); height: 200px;">
      <svg viewBox="0 0 1200 200" class="w-full h-full" preserveAspectRatio="none">
        <defs>
          <linearGradient id="stages-flow" x1="0%" y1="50%" x2="100%" y2="50%">
            <stop offset="0%" stop-color="#2d5a3f" stop-opacity="0.6"/>
            <stop offset="50%" stop-color="#b8721c" stop-opacity="0.8"/>
            <stop offset="100%" stop-color="#8b2c4d" stop-opacity="0.6"/>
          </linearGradient>
        </defs>
        <path
          id="stages-path"
          d="M 80 100 Q 300 60, 500 100 T 900 100 Q 1050 140, 1120 100"
          stroke="url(#stages-flow)"
          stroke-width="2"
          stroke-dasharray="4 6"
          fill="none"
          stroke-linecap="round"
          style="stroke-dashoffset: 1500; transition: stroke-dashoffset 2s cubic-bezier(0.16, 1, 0.3, 1);"
        />
        <circle r="4" fill="#5b3aa3">
          <animateMotion
            dur="8s"
            repeatCount="indefinite"
            path="M 80 100 Q 300 60, 500 100 T 900 100 Q 1050 140, 1120 100"
          />
        </circle>
        <circle r="3" fill="#8b2c4d">
          <animateMotion
            dur="8s"
            begin="3s"
            repeatCount="indefinite"
            path="M 80 100 Q 300 60, 500 100 T 900 100 Q 1050 140, 1120 100"
          />
        </circle>
      </svg>
    </div>

    <!-- Stages -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6 mb-20 relative">
      {stages.map((stage, index) => (
        <article
          class={`stage-card group relative rounded-3xl paper-elevated overflow-hidden transition-all duration-700 ${index === 1 ? 'md:-translate-y-6 ring-2 ring-accent/20' : ''}`}
          data-stage={stage.id}
          style={`--stage-color: var(--color-${stage.accent});`}
        >
          <!-- Accent-Top-Bar in stage-Farbe -->
          <div class="absolute top-0 left-0 right-0 h-1 pointer-events-none" style={`background: linear-gradient(90deg, transparent, var(--color-${stage.accent}), transparent); opacity: 0.9;`}></div>

          <!-- Soft radial glow hinter dem Visual (deeper depth) -->
          <div
            class="absolute pointer-events-none transition-opacity duration-700 group-hover:opacity-70"
            style={`top: 18%; left: 50%; transform: translateX(-50%); width: 60%; height: 200px; background: radial-gradient(ellipse at center, var(--color-${stage.accent}) 0%, transparent 65%); opacity: 0.12;`}
          ></div>

          <!-- Dotted background pattern — subtle depth -->
          <div
            class="absolute inset-0 pointer-events-none opacity-[0.04] group-hover:opacity-[0.07] transition-opacity duration-700"
            style={`background-image: radial-gradient(var(--color-${stage.accent}) 1px, transparent 1px); background-size: 16px 16px;`}
          ></div>

          <!-- Watermark-Initials top-right, innerhalb der Card, nicht abgeschnitten -->
          <div
            class="absolute top-4 right-5 font-display font-normal leading-none pointer-events-none select-none transition-all duration-700 group-hover:scale-105"
            style={`font-size: clamp(5rem, 11vw, 8rem); color: var(--color-${stage.accent}); opacity: 0.08; letter-spacing: -0.08em;`}
            aria-hidden="true"
          >
            {stage.label}
          </div>

          <div class="relative p-8 md:p-10">
            <div class="flex items-center justify-between mb-6">
              <div class="font-mono text-[10px] uppercase tracking-[0.25em] text-text-muted">
                Stufe {index + 1}
              </div>
              <div class={`badge ${stage.badgeClass}`}>
                {stage.status}
              </div>
            </div>

            <!-- Big abbreviation — solid, ohne Outline-Layer -->
            <div class="mb-6">
              <div class="font-display text-[clamp(4rem,11vw,7rem)] leading-none tracking-tighter text-text-primary">
                {stage.label}
              </div>
              <div class="font-display italic text-xl md:text-2xl text-text-muted mt-1">
                {stage.title}
              </div>
            </div>

            <!-- Visual mit Ring-Glow hinter dem SVG -->
            <div class="flex justify-center mb-6 h-28 relative">
              <!-- Layered concentric rings — Tiefen-Illusion -->
              <div
                class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 rounded-full pointer-events-none transition-transform duration-700 group-hover:scale-110"
                style={`width: 140px; height: 140px; background: radial-gradient(circle, var(--color-${stage.accent}) 0%, transparent 70%); opacity: 0.15;`}
              ></div>
              <div
                class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 rounded-full border pointer-events-none"
                style={`width: 170px; height: 170px; border-color: var(--color-${stage.accent}); opacity: 0.15;`}
              ></div>

              {stage.visual === 'simple' && (
                <svg viewBox="0 0 100 100" class="relative w-28 h-28">
                  <circle cx="50" cy="50" r="35" fill="none" stroke="var(--color-forest)" stroke-width="0.4" opacity="0.3" stroke-dasharray="2 3"/>
                  <circle cx="50" cy="50" r="22" fill="none" stroke="var(--color-forest)" stroke-width="0.6" opacity="0.5"/>
                  <circle cx="50" cy="50" r="14" fill="var(--color-forest)" opacity="0.15"/>
                  <circle cx="50" cy="50" r="8" fill="var(--color-forest)"/>
                  <circle cx="50" cy="50" r="3" fill="#faf6ed"/>
                </svg>
              )}
              {stage.visual === 'network' && (
                <svg viewBox="0 0 100 100" class="relative w-28 h-28 stage-network">
                  <!-- Outer orbit -->
                  <circle cx="50" cy="50" r="40" fill="none" stroke="var(--color-accent)" stroke-width="0.3" opacity="0.2" stroke-dasharray="1 2"/>
                  <g class="rotate-network" style="transform-origin: 50% 50%;">
                    <circle cx="50" cy="50" r="10" fill="var(--color-accent)" opacity="0.2"/>
                    <circle cx="50" cy="50" r="6" fill="var(--color-accent-deep)"/>
                    {[0, 60, 120, 180, 240, 300].map((angle) => {
                      const rad = (angle * Math.PI) / 180;
                      const x = 50 + Math.cos(rad) * 30;
                      const y = 50 + Math.sin(rad) * 30;
                      return (
                        <>
                          <line x1="50" y1="50" x2={x} y2={y} stroke="var(--color-accent)" stroke-width="0.6" opacity="0.55"/>
                          <circle cx={x} cy={y} r="4.5" fill="var(--color-accent)" opacity="0.2"/>
                          <circle cx={x} cy={y} r="3" fill="var(--color-accent)"/>
                        </>
                      );
                    })}
                    <!-- Inter-node connections for richer graph feel -->
                    {[[0, 120], [60, 180], [120, 240], [180, 300], [240, 0], [300, 60]].map(([a, b]) => {
                      const ra = (a * Math.PI) / 180;
                      const rb = (b * Math.PI) / 180;
                      return (
                        <line
                          x1={50 + Math.cos(ra) * 30}
                          y1={50 + Math.sin(ra) * 30}
                          x2={50 + Math.cos(rb) * 30}
                          y2={50 + Math.sin(rb) * 30}
                          stroke="var(--color-accent)"
                          stroke-width="0.3"
                          opacity="0.25"
                        />
                      );
                    })}
                  </g>
                </svg>
              )}
              {stage.visual === 'explosion' && (
                <svg viewBox="0 0 100 100" class="relative w-28 h-28">
                  <!-- Shockwave rings -->
                  <circle cx="50" cy="50" r="42" fill="none" stroke="var(--color-burgundy)" stroke-width="0.3" opacity="0.2" stroke-dasharray="1 3"/>
                  <circle cx="50" cy="50" r="30" fill="none" stroke="var(--color-burgundy)" stroke-width="0.3" opacity="0.3"/>
                  <circle cx="50" cy="50" r="12" fill="var(--color-burgundy)" opacity="0.2"/>
                  <circle cx="50" cy="50" r="6" fill="var(--color-burgundy)"/>
                  {[...Array(16).keys()].map((i) => {
                    const angle = (i * 22.5 * Math.PI) / 180;
                    const len = 32 + (i % 3) * 8;
                    return (
                      <line
                        x1={50 + Math.cos(angle) * 10}
                        y1={50 + Math.sin(angle) * 10}
                        x2={50 + Math.cos(angle) * len}
                        y2={50 + Math.sin(angle) * len}
                        stroke="var(--color-burgundy)"
                        stroke-width={i % 2 === 0 ? '0.7' : '0.4'}
                        stroke-linecap="round"
                        opacity={i % 2 === 0 ? 0.75 : 0.35}
                      />
                    );
                  })}
                </svg>
              )}
            </div>

            <p class="text-text-secondary text-sm leading-relaxed mb-5">
              {stage.description}
            </p>

            <!-- Human analogy — immer sichtbar, kleines Zitat -->
            <div class="mb-6 pl-4 border-l-2 text-text-primary/80 text-[13px] leading-relaxed italic" style={`border-color: var(--color-${stage.accent});`}>
              {stage.humanAnalogy}
            </div>

            <!-- Reveal area on hover / tap -->
            <div class="stage-reveal space-y-4 overflow-hidden">
              <div>
                <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-2">
                  Was sie können
                </div>
                <ul class="space-y-1.5">
                  {stage.abilities.map((a) => (
                    <li class="flex items-start gap-2 text-[13px] text-text-primary leading-snug">
                      <span class="mt-1.5 w-1 h-1 rounded-full shrink-0" style={`background: var(--color-${stage.accent});`}></span>
                      <span>{a}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div>
                <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-2">
                  Was noch fehlt
                </div>
                <p class="text-[13px] text-text-secondary leading-relaxed">
                  {stage.stillMissing}
                </p>
              </div>
            </div>

            <div class="space-y-3 pt-6 mt-6 border-t border-border">
              <div>
                <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-2">Beispiele</div>
                <div class="flex flex-wrap gap-1.5">
                  {stage.examples.map((ex) => (
                    <span class="text-[11px] font-mono px-2 py-1 rounded-md bg-bg-secondary text-text-secondary">
                      {ex}
                    </span>
                  ))}
                </div>
              </div>
              <div>
                <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-2">Zeitraum</div>
                <div class="text-xs text-text-primary font-medium">{stage.timeframe}</div>
              </div>
            </div>

            <!-- Hover indicator -->
            <div class="stage-hover-hint absolute bottom-4 right-4 text-[10px] font-mono uppercase tracking-[0.2em] text-text-muted opacity-70 transition-opacity duration-300 pointer-events-none">
              Details ↓
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Quote -->
    <div class="max-w-3xl mx-auto">
      <figure class="relative pl-6 md:pl-10">
        <div class="absolute left-0 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-accent to-transparent"></div>
        <blockquote class="font-display italic text-2xl md:text-3xl lg:text-4xl text-text-primary leading-snug">
          "AGI ist ein System, das mindestens so intelligent wie ein Mensch ist —
          <span class="gradient-text not-italic">über die gesamte Bandbreite</span>
          kognitiver Aufgaben hinweg."
        </blockquote>
        <figcaption class="mt-6 flex items-center gap-3 text-sm text-text-muted">
          <span class="w-12 h-px bg-text-muted"></span>
          <span class="font-mono uppercase tracking-wider text-xs">Shane Legg · Mitgründer Google DeepMind · 2007</span>
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<style>
  @keyframes rotate-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .rotate-network {
    animation: rotate-slow 40s linear infinite;
  }

  /* Hover-Depth: tiefere Shadow + subtiler Lift */
  .stage-card {
    box-shadow:
      0 1px 2px rgba(26, 24, 20, 0.04),
      0 4px 12px -2px rgba(26, 24, 20, 0.06),
      0 20px 40px -12px rgba(26, 24, 20, 0.08);
  }
  .stage-card:hover {
    box-shadow:
      0 1px 2px rgba(26, 24, 20, 0.06),
      0 8px 20px -4px rgba(91, 58, 163, 0.1),
      0 30px 60px -16px rgba(26, 24, 20, 0.14);
  }
  .stage-card[data-stage="agi"]:hover {
    box-shadow:
      0 1px 2px rgba(26, 24, 20, 0.06),
      0 10px 24px -4px rgba(91, 58, 163, 0.2),
      0 40px 70px -20px rgba(91, 58, 163, 0.18);
  }

  /* Reveal-Area: collapsed by default, expands on hover (Desktop) oder .is-open (tap) */
  .stage-reveal {
    max-height: 0;
    opacity: 0;
    transition:
      max-height 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.45s ease,
      margin 0.5s;
    margin-top: 0;
  }
  .stage-card:hover .stage-reveal,
  .stage-card.is-open .stage-reveal,
  .stage-card:focus-within .stage-reveal {
    max-height: 500px;
    opacity: 1;
    margin-top: 0.25rem;
  }
  .stage-card:hover .stage-hover-hint,
  .stage-card.is-open .stage-hover-hint {
    opacity: 0;
  }

  /* Touch-Geräte: immer sichtbar (kein Hover) */
  @media (hover: none) {
    .stage-reveal { max-height: 500px; opacity: 1; margin-top: 0.25rem; }
    .stage-hover-hint { display: none; }
  }
</style>

<script>
  // Tap-to-expand fallback für Tablets die weder hover noch touch only sind
  document.querySelectorAll<HTMLElement>('.stage-card').forEach((card) => {
    card.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('a, button')) return;
      card.classList.toggle('is-open');
    });
  });
</script>
