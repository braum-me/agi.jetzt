---
const navItems = [
  { label: 'Übersicht', href: '/' },
  { label: 'Dashboard', href: '/dashboard' },
  { label: 'Briefing', href: '/briefing' },
];

const moreItems = [
  { label: 'Chronik', href: '/geschichte', desc: '12 Momente · Prognosen' },
  { label: 'Kapital', href: '/kapital', desc: 'Investment-Flows' },
  { label: 'Globaler Wettlauf', href: '/laender', desc: 'Länder + Ökosystem' },
  { label: 'Compute', href: '/compute', desc: 'Exponential-Kurve' },
  { label: 'Debatten & Risiken', href: '/kontroversen', desc: 'Kontroversen' },
  { label: 'Glossar', href: '/glossar', desc: '18 Begriffe' },
  { label: 'Methodik', href: '/methodik', desc: 'Pipeline & Quellen' },
];
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 transition-all duration-500" style="z-index: 90;">
  <div class="section-container">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="group flex items-center gap-2.5 font-display text-xl md:text-2xl font-normal tracking-tight" aria-label="Zur Startseite">
        <!-- Editorial mark — circle with brain trace -->
        <span class="relative flex items-center justify-center w-9 h-9 rounded-full bg-bg-ink overflow-hidden">
          <svg class="w-5 h-5 text-bg-primary" fill="none" viewBox="0 0 24 24">
            <path d="M9 7c0-1.1.9-2 2-2h2c1.1 0 2 .9 2 2v2.5M9 7v2.5M9 7c-1.1 0-2 .9-2 2v2c0 1.1.9 2 2 2M15 9.5V12c0 1.1-.9 2-2 2M15 9.5c1.1 0 2 .9 2 2s-.9 2-2 2M9 12c0 1.1.9 2 2 2v3M9 12v3M11 17c0 1.1.9 2 2 2h0c1.1 0 2-.9 2-2v-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="12" cy="12" r="0.8" fill="currentColor"/>
          </svg>
        </span>
        <span class="text-text-primary leading-none">
          agi<span class="text-text-muted">.</span><span class="italic">jetzt</span>
        </span>
      </a>

      <!-- Desktop Nav — editorial pills -->
      <ul class="hidden md:flex items-center gap-1 paper rounded-full px-1.5 py-1.5 nav-pill-container">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="nav-link group inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-bg-card-hover transition-all duration-300"
            >
              <span>{item.label}</span>
            </a>
          </li>
        ))}
        <!-- Mehr-Dropdown -->
        <li class="relative" id="more-menu-wrap">
          <button
            type="button"
            id="more-toggle"
            class="nav-link group inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-bg-card-hover transition-all duration-300"
            aria-haspopup="true"
            aria-expanded="false"
          >
            <span>Mehr</span>
            <svg class="w-3 h-3 transition-transform" id="more-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div
            id="more-menu"
            class="absolute right-0 top-full mt-3 w-72 rounded-2xl paper-elevated p-2 opacity-0 pointer-events-none translate-y-1 transition-all duration-200"
            style="z-index: 100;"
          >
            {moreItems.map((m) => (
              <a
                href={m.href}
                class="block px-3 py-2.5 rounded-xl hover:bg-bg-card-hover transition-colors group"
              >
                <div class="text-sm font-medium text-text-primary group-hover:text-accent-deep transition-colors">{m.label}</div>
                <div class="text-[11px] font-mono text-text-muted mt-0.5">{m.desc}</div>
              </a>
            ))}
          </div>
        </li>
      </ul>

      <!-- CTA — high contrast -->
      <a
        href="#about"
        class="hidden md:inline-flex items-center gap-2 px-4 py-2 rounded-full bg-bg-ink text-bg-primary text-sm font-medium hover:bg-accent-deep transition-all duration-300 group"
      >
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
        </svg>
        <span>Stefan Braum</span>
        <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-toggle"
        class="md:hidden relative w-10 h-10 flex items-center justify-center"
        aria-label="Menü öffnen"
        aria-expanded="false"
      >
        <div class="hamburger-lines">
          <span class="block w-5 h-0.5 bg-text-primary transition-all duration-300 origin-center"></span>
          <span class="block w-5 h-0.5 bg-text-primary transition-all duration-300 mt-1.5"></span>
          <span class="block w-5 h-0.5 bg-text-primary transition-all duration-300 mt-1.5"></span>
        </div>
      </button>
    </div>
  </div>

  <!-- Mobile Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-40 flex flex-col items-center justify-center gap-10 opacity-0 pointer-events-none transition-opacity duration-500 px-6 overflow-y-auto py-20"
    style="background: rgba(245, 241, 232, 0.98); backdrop-filter: blur(40px);"
  >
    <!-- Top-Level -->
    <ul class="flex flex-col items-center gap-5">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="mobile-nav-link font-display text-3xl md:text-4xl text-text-secondary hover:text-accent-deep transition-colors duration-300"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
    <!-- Mehr-Section -->
    <div class="text-center w-full max-w-sm">
      <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-4">Mehr</div>
      <ul class="space-y-2">
        {moreItems.map((m) => (
          <li>
            <a
              href={m.href}
              class="mobile-nav-link block py-2 text-text-secondary hover:text-accent-deep transition-colors"
            >
              <span class="font-display text-lg">{m.label}</span>
              <span class="block text-[11px] font-mono text-text-muted mt-0.5">{m.desc}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>

<style>
  /* Initial state: transparent */
  #main-nav {
    background: transparent;
  }

  /* Scrolled state: paper-like surface */
  #main-nav.scrolled {
    background: rgba(245, 241, 232, 0.85);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid var(--color-border);
  }

  /* Editorial pill container - subtle inset */
  .nav-pill-container {
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.6),
      0 1px 3px rgba(26, 24, 20, 0.05);
  }
</style>

<script>
  const nav = document.getElementById('main-nav');
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  let isOpen = false;

  const updateNav = () => {
    if (!nav) return;
    if (window.scrollY > 50) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
  };
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  toggle?.addEventListener('click', () => {
    isOpen = !isOpen;
    if (!menu || !toggle) return;

    if (isOpen) {
      menu.classList.remove('opacity-0', 'pointer-events-none');
      menu.classList.add('opacity-100');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      const lines = toggle.querySelectorAll('.hamburger-lines span');
      lines[0]?.classList.add('rotate-45', 'translate-y-[8px]');
      lines[1]?.classList.add('opacity-0');
      lines[2]?.classList.add('-rotate-45', '-translate-y-[8px]');
    } else {
      menu.classList.add('opacity-0', 'pointer-events-none');
      menu.classList.remove('opacity-100');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      const lines = toggle.querySelectorAll('.hamburger-lines span');
      lines[0]?.classList.remove('rotate-45', 'translate-y-[8px]');
      lines[1]?.classList.remove('opacity-0');
      lines[2]?.classList.remove('-rotate-45', '-translate-y-[8px]');
    }
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (!isOpen) return;
      isOpen = false;
      menu.classList.add('opacity-0', 'pointer-events-none');
      menu.classList.remove('opacity-100');
      toggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      const lines = toggle?.querySelectorAll('.hamburger-lines span');
      lines?.[0]?.classList.remove('rotate-45', 'translate-y-[8px]');
      lines?.[1]?.classList.remove('opacity-0');
      lines?.[2]?.classList.remove('-rotate-45', '-translate-y-[8px]');
    });
  });

  // Active route highlighting (Top-Level)
  const path = window.location.pathname;
  document.querySelectorAll<HTMLElement>('.nav-link').forEach((link) => {
    const href = link.getAttribute('href') || '';
    const isActive =
      (href === '/' && path === '/') ||
      (href !== '/' && path.startsWith(href));
    if (isActive) {
      link.classList.add('text-text-primary', 'bg-bg-card-hover');
      link.classList.remove('text-text-secondary');
    }
  });

  // "Mehr"-Dropdown
  const moreToggle = document.getElementById('more-toggle');
  const moreMenu = document.getElementById('more-menu');
  const moreChevron = document.getElementById('more-chevron');
  const moreWrap = document.getElementById('more-menu-wrap');
  let moreOpen = false;

  const setMore = (open: boolean) => {
    if (!moreMenu || !moreToggle || !moreChevron) return;
    moreOpen = open;
    moreToggle.setAttribute('aria-expanded', String(open));
    if (open) {
      moreMenu.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-1');
      moreMenu.classList.add('opacity-100');
      moreChevron.style.transform = 'rotate(180deg)';
    } else {
      moreMenu.classList.add('opacity-0', 'pointer-events-none', 'translate-y-1');
      moreMenu.classList.remove('opacity-100');
      moreChevron.style.transform = '';
    }
  };

  moreToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    setMore(!moreOpen);
  });
  document.addEventListener('click', (e) => {
    if (moreOpen && moreWrap && !moreWrap.contains(e.target as Node)) setMore(false);
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && moreOpen) setMore(false);
  });
</script>
