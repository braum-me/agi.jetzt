---
interface Props {
  key: string;
  label: string;
  digits: number;
  visible?: string;
  pulse?: boolean;
}

const { key, label, digits, visible = '', pulse = false } = Astro.props;
// Placeholder rein visuell für SSR — JS überschreibt das beim ersten Tick.
const placeholder = digits >= 3 ? '—' : '—';
---

<div class={`flex flex-col items-center ${visible}`}>
  <div class="relative">
    <div class={`font-display font-normal text-[clamp(2rem,6.5vw,5rem)] leading-none tabular-nums tracking-tight ${pulse ? 'text-burgundy' : 'text-text-primary'}`} data-c={key}>
      {placeholder}
    </div>
  </div>
  <div class="mt-2 text-[10px] md:text-xs font-mono uppercase tracking-[0.2em] text-text-muted">
    {label}
  </div>
</div>
