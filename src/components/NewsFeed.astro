---
import NewsCard from './NewsCard.astro';
import newsData from '../data/news.json';

const sortedNews = newsData.sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

const categories = [
  { key: 'alle',        label: 'Alle',        color: '#1a1814' },
  { key: 'research',    label: 'Research',    color: '#5b3aa3' },
  { key: 'industrie',   label: 'Industrie',   color: '#1a1814' },
  { key: 'open_source', label: 'Open Source', color: '#2d5a3f' },
  { key: 'politik',     label: 'Politik',     color: '#b8721c' },
  { key: 'produkt',     label: 'Produkt',     color: '#8b2c4d' },
];

const counts = sortedNews.reduce<Record<string, number>>((acc, n) => {
  acc[n.category] = (acc[n.category] || 0) + 1;
  return acc;
}, {});
counts['alle'] = sortedNews.length;
---

<section id="news" class="relative py-20 md:py-28 overflow-hidden">
  <div class="section-container relative">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12 md:mb-16">
      <div>
        <div class="badge mb-6">
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full rounded-full bg-burgundy opacity-75 animate-pulse"></span>
            <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-burgundy"></span>
          </span>
          Live Feed
        </div>
        <h2 class="font-display font-normal text-balance leading-[1.05] text-[clamp(1.875rem,6vw,5rem)]">
          Was <em class="italic gradient-text">heute</em><br/>
          die KI-Welt bewegt
        </h2>
      </div>
      <p class="md:max-w-xs text-text-secondary text-sm leading-relaxed">
        Kuratierte Headlines aus Research, Industrie und Politik. Aktualisiert in Echtzeit durch automatisierte KI-Workflows.
      </p>
    </div>

    <!-- Filter Bar -->
    <div class="flex flex-wrap gap-2 mb-12" id="news-filters">
      {categories.map((cat) => (
        <button
          type="button"
          class={`news-filter-btn group inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full text-xs font-mono uppercase tracking-[0.08em] font-medium border transition-all duration-300 ${
            cat.key === 'alle'
              ? 'is-active text-bg-primary border-transparent'
              : 'text-text-secondary hover:text-text-primary'
          }`}
          style={cat.key === 'alle'
            ? `background: ${cat.color}; border-color: ${cat.color};`
            : `background: transparent; border-color: ${cat.color}55;`}
          data-filter={cat.key}
          data-color={cat.color}
        >
          <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background: ${cat.color};`}></span>
          {cat.label}
          <span class={`ml-0.5 text-[10px] font-normal opacity-70`}>{counts[cat.key] || 0}</span>
        </button>
      ))}
    </div>

    <!-- News-Grid — initial 6 Desktop / 3 Mobile, Rest verborgen via [data-hidden-initial] -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6 auto-rows-fr" id="news-grid">
      {sortedNews.map((news, i) => (
        <div
          class="news-item-wrap flex"
          data-hidden-initial={i >= 3 ? (i >= 6 ? 'desktop-hidden' : 'mobile-hidden') : undefined}
        >
          <NewsCard
            headline={news.headline}
            summary={news.summary}
            category={news.category}
            source={news.source}
            sourceUrl={news.source_url}
            date={news.date}
            relevanceScore={news.relevance_score}
            variant={i === 0 ? 'featured' : 'default'}
          />
        </div>
      ))}
    </div>

    <!-- Load more + Link zum Dashboard-NewsFeed -->
    <div class="flex flex-col items-center gap-3 mt-10">
      <button
        id="news-load-more"
        type="button"
        class="btn-secondary group"
      >
        <span>Mehr News laden</span>
        <span class="font-mono text-[10px] opacity-60" id="news-load-counter"></span>
        <svg class="w-4 h-4 transition-transform group-hover:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </button>
      <a href="/dashboard#news" class="text-xs font-mono text-text-muted hover:text-text-primary transition-colors">
        Oder: alle News im Dashboard ansehen →
      </a>
    </div>
  </div>
</section>

<style>
  /* Hide extra items until user clicks "Load more". Responsive:
     Mobile zeigt initial 3, Desktop (md+) zeigt initial 6. */
  .news-item-wrap[data-hidden-initial="mobile-hidden"] {
    display: none;
  }
  @media (min-width: 768px) {
    .news-item-wrap[data-hidden-initial="mobile-hidden"] { display: flex; }
    .news-item-wrap[data-hidden-initial="desktop-hidden"] { display: none; }
  }
  .news-item-wrap.is-revealed {
    display: flex !important;
    animation: news-reveal 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes news-reveal {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.news-filter-btn');
  const newsWraps = document.querySelectorAll<HTMLElement>('.news-item-wrap');
  const loadMoreBtn = document.getElementById('news-load-more') as HTMLButtonElement | null;
  const loadCounter = document.getElementById('news-load-counter');

  let currentFilter = 'alle';

  const setActive = (btn: HTMLButtonElement) => {
    filterBtns.forEach((b) => {
      const c = b.dataset.color || '#1a1814';
      b.classList.remove('is-active');
      b.style.background = 'transparent';
      b.style.borderColor = `${c}55`;
      b.style.color = '';
    });
    const color = btn.dataset.color || '#1a1814';
    btn.classList.add('is-active');
    btn.style.background = color;
    btn.style.borderColor = color;
    btn.style.color = 'var(--color-bg-primary)';
  };

  const updateLoadMore = () => {
    if (!loadMoreBtn || !loadCounter) return;
    // Filter: wir zählen innerhalb der aktiven Kategorie
    const all = Array.from(newsWraps).filter((w) => {
      const card = w.querySelector<HTMLElement>('.news-card');
      return currentFilter === 'alle' || card?.dataset.category === currentFilter;
    });
    const hidden = all.filter((w) => {
      if (w.classList.contains('is-revealed')) return false;
      return w.dataset.hiddenInitial === 'mobile-hidden' || w.dataset.hiddenInitial === 'desktop-hidden';
    });
    // Auf Mobile gelten auch die mobile-hidden als versteckt
    const isMobile = window.matchMedia('(max-width: 767px)').matches;
    const effectivelyHidden = all.filter((w) => {
      if (w.classList.contains('is-revealed')) return false;
      if (!w.dataset.hiddenInitial) return false;
      if (isMobile) return true; // alle hidden-Klassen sind mobile versteckt
      return w.dataset.hiddenInitial === 'desktop-hidden';
    });

    if (effectivelyHidden.length === 0) {
      loadMoreBtn.style.display = 'none';
    } else {
      loadMoreBtn.style.display = '';
      loadCounter.textContent = `+${Math.min(6, effectivelyHidden.length)}  ·  noch ${effectivelyHidden.length}`;
    }
  };

  loadMoreBtn?.addEventListener('click', () => {
    const isMobile = window.matchMedia('(max-width: 767px)').matches;
    let revealed = 0;
    for (const wrap of newsWraps) {
      if (revealed >= 6) break;
      if (wrap.classList.contains('is-revealed')) continue;
      if (!wrap.dataset.hiddenInitial) continue;
      const card = wrap.querySelector<HTMLElement>('.news-card');
      if (currentFilter !== 'alle' && card?.dataset.category !== currentFilter) continue;
      // mobile: alles hidden aufdecken; desktop: nur desktop-hidden
      if (!isMobile && wrap.dataset.hiddenInitial === 'mobile-hidden') continue;
      wrap.classList.add('is-revealed');
      revealed++;
    }
    updateLoadMore();
  });

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      setActive(btn);
      currentFilter = btn.dataset.filter || 'alle';

      newsWraps.forEach((wrap) => {
        const card = wrap.querySelector<HTMLElement>('.news-card');
        if (currentFilter === 'alle' || card?.dataset.category === currentFilter) {
          wrap.style.display = '';
        } else {
          wrap.style.display = 'none';
        }
      });
      updateLoadMore();
    });
  });

  updateLoadMore();
  window.addEventListener('resize', updateLoadMore);
</script>
