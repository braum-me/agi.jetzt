---
import Layout from './Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import CommandPalette from '../components/CommandPalette.astro';

interface Props {
  title: string;
  description?: string;
  label: string;
  eyebrow: string;
  seoTitle?: string;
  image?: string;
}

const { title, description, label, eyebrow, seoTitle, image } = Astro.props;
const finalTitle = seoTitle ?? `${label} — agi.jetzt`;

// Aktuellen Pfad ermitteln, um in der "Mehr Deep Dives"-Row sich selbst auszuschließen
const currentPath = Astro.url.pathname.replace(/\/$/, '');

const allDeepDives = [
  { slug: '/geschichte', label: 'Chronik', desc: '12 Momente · Prognosen', accent: '#5b3aa3' },
  { slug: '/kapital', label: 'Kapital', desc: 'Investment-Flows', accent: '#b8721c' },
  { slug: '/laender', label: 'Globaler Wettlauf', desc: 'Länder + Ökosystem', accent: '#2d5a3f' },
  { slug: '/compute', label: 'Compute', desc: 'Exponential-Kurve', accent: '#8b2c4d' },
  { slug: '/kontroversen', label: 'Debatten & Risiken', desc: 'Kontroversen', accent: '#8b4a2c' },
  { slug: '/glossar', label: 'Glossar', desc: '18 Begriffe', accent: '#3d2670' },
  { slug: '/methodik', label: 'Methodik', desc: 'Pipeline & Quellen', accent: '#2d5a3f' },
];
const otherDives = allDeepDives.filter((d) => d.slug !== currentPath).slice(0, 3);
---

<Layout title={finalTitle} description={description} image={image}>
  <Navigation />

  <main id="main" class="pt-28 md:pt-36">
    <!-- Back to home -->
    <div class="section-container mb-8">
      <a href="/" class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-text-primary transition-colors group">
        <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        <span class="font-mono uppercase tracking-[0.2em] text-[10px]">Zurück zur Übersicht</span>
      </a>
    </div>

    <!-- Deep dive header -->
    <div data-pagefind-body data-glossary-scope data-pagefind-meta={`title:${title}`}>
      <div class="section-container text-center mb-12 md:mb-20">
        <div class="badge mx-auto mb-6">
          <span class="w-1 h-1 rounded-full bg-accent"></span>
          Deep Dive · {eyebrow}
        </div>
        <h1 class="font-display font-normal text-balance leading-[1.05] text-[clamp(2.75rem,7vw,6rem)]">
          {title}
        </h1>
      </div>

      <slot />
    </div>

    <!-- Doppel-CTA: Dashboard + Briefing -->
    <div class="section-container mt-24 md:mt-32">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-4xl mx-auto">
        <a
          href="/dashboard"
          class="group block paper-elevated rounded-3xl p-7 md:p-8 transition-all hover:bg-bg-card-hover hover:-translate-y-0.5"
        >
          <div class="shrink-0 w-12 h-12 rounded-2xl flex items-center justify-center bg-bg-ink text-bg-primary mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h7v7H3V3zm11 0h7v7h-7V3zm0 11h7v7h-7v-7zM3 14h7v7H3v-7z"/>
            </svg>
          </div>
          <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-2">
            Live-Daten
          </div>
          <div class="font-display text-xl md:text-2xl text-text-primary leading-tight mb-2 group-hover:text-accent-deep transition-colors">
            Alle Daten im Dashboard →
          </div>
          <p class="text-sm text-text-secondary leading-relaxed">
            17 Widgets, alle quellenbasiert, quartalsweise aktualisiert.
          </p>
        </a>

        <a
          href="/briefing"
          class="group block paper-elevated rounded-3xl p-7 md:p-8 transition-all hover:bg-bg-card-hover hover:-translate-y-0.5"
        >
          <div class="shrink-0 w-12 h-12 rounded-2xl flex items-center justify-center bg-burgundy text-bg-primary mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9.5a1.5 1.5 0 0 0-1.5-1.5H17M9 3v2m6-2v2M9 11h4m-4 4h2"/>
            </svg>
          </div>
          <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-2">
            Wöchentlich · Freitags
          </div>
          <div class="font-display text-xl md:text-2xl text-text-primary leading-tight mb-2 group-hover:text-accent-deep transition-colors">
            Zum aktuellen Briefing →
          </div>
          <p class="text-sm text-text-secondary leading-relaxed">
            Eingeordnete Analyse zum AI-Geschehen der Woche.
          </p>
        </a>
      </div>

      <!-- Andere Deep Dives -->
      <div class="max-w-4xl mx-auto mt-12 pt-10 border-t border-border">
        <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-text-muted mb-5 text-center">
          Andere Deep Dives
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          {otherDives.map((d) => (
            <a
              href={d.slug}
              class="group relative paper-elevated rounded-2xl p-5 hover:bg-bg-card-hover hover:-translate-y-0.5 transition-all overflow-hidden"
            >
              <div class="absolute top-0 left-0 right-0 h-1" style={`background: ${d.accent};`}></div>
              <div class="text-[10px] font-mono uppercase tracking-[0.25em] mb-2" style={`color: ${d.accent};`}>
                {d.slug}
              </div>
              <div class="font-display text-lg text-text-primary leading-tight group-hover:text-accent-deep transition-colors">
                {d.label}
              </div>
              <div class="text-xs text-text-muted mt-1">{d.desc}</div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </main>

  <Footer />
  <CommandPalette />

  <script>
    import { initCursorEffects, initScrollProgress, initMagneticButtons } from '../scripts/cursor-effects';
    import { initConsoleMessage, initKonamiCode, initLogoSecret, initFocusBlur } from '../scripts/easter-eggs';
    import { initGlossaryTooltips } from '../scripts/glossary-tooltips';
    initCursorEffects();
    initScrollProgress();
    initMagneticButtons();
    initConsoleMessage();
    initKonamiCode();
    initLogoSecret();
    initFocusBlur();
    initGlossaryTooltips();
  </script>
</Layout>
