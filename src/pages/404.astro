---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Nicht gefunden – agi.jetzt"
  description="Diese Seite existiert nicht (mehr). Zurück zur Startseite."
>
  <Navigation />

  <main id="main" class="min-h-[70vh] flex items-center justify-center py-24 md:py-32">
    <div class="section-container text-center max-w-2xl mx-auto">
      <div class="font-display text-[clamp(6rem,18vw,14rem)] leading-none tracking-tighter gradient-text mb-4">
        404
      </div>
      <h1 class="font-display font-normal text-balance leading-[1.05] text-[clamp(2rem,5vw,3.5rem)] mb-6">
        Diese Seite gibt es <em class="italic gradient-text">nicht</em>.
      </h1>
      <p class="text-text-secondary text-lg leading-relaxed mb-10">
        Entweder wurde der Link falsch geschrieben, oder die Seite wurde
        umbenannt. Kommt vor.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/" class="btn-primary">
          Zurück zur Startseite
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="/dashboard" class="btn-secondary">
          Zum Dashboard
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
